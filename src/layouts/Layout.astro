---
interface Props {
	title?: string;
}

const { title = "Japanezy Arts" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/japanezy-logo-v2.png" />
		<meta name="description" content="Japanezy Arts - Japanese-inspired artwork, tutorials, and original pieces for sale." />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
	</head>
	<body>

		<nav class="nav">
			<a href="/" class="nav-logo-link">
				<img src="/japanezy-logo-v2.png" alt="Japanezy Arts" class="nav-logo" />
			</a>
			<button class="hamburger" id="hamburger" aria-label="Toggle menu">
				<span></span>
				<span></span>
				<span></span>
			</button>
			<div class="nav-links" id="nav-links">
				<a href="/" class="nav-link">Home</a>
				<span class="nav-paw"><img src="/paw-icon.svg" alt="" width="18" height="18" /></span>
				<a href="/rosey" class="nav-link">Rosey</a>
				<span class="nav-paw"><img src="/paw-icon.svg" alt="" width="18" height="18" /></span>
				<a href="/art" class="nav-link">Artkai</a>
				<span class="nav-paw"><img src="/paw-icon.svg" alt="" width="18" height="18" /></span>
				<a href="/printable" class="nav-link">Freebies</a>
				<span class="nav-paw"><img src="/paw-icon.svg" alt="" width="18" height="18" /></span>
				<a href="/puchipaws" class="nav-link">PuchiPaws</a>
				<span class="nav-paw"><img src="/paw-icon.svg" alt="" width="18" height="18" /></span>
				<a href="/shorts" class="nav-link">Videos</a>
				<span class="nav-paw"><img src="/paw-icon.svg" alt="" width="18" height="18" /></span>
				<a href="#about" class="nav-link">About</a>
			</div>
		</nav>

		<!-- Spin the Wheel Modal -->
		<div class="wheel-overlay" id="wheel-overlay">
			<div class="wheel-modal">
				<button class="wheel-close" id="wheel-close">&times;</button>
				<h2 class="wheel-title">Spin the Wheel!</h2>
				<div class="wheel-container">
					<div class="wheel-arrow"></div>
					<canvas id="wheel-canvas" width="320" height="320"></canvas>
				</div>
				<div class="wheel-btn-row">
					<button class="wheel-spin-btn" id="spin-btn">Spin</button>
					<button class="wheel-stop-btn" id="stop-btn" style="display:none;">Stop</button>
				</div>
				<p class="wheel-result" id="wheel-result"></p>
				<div class="unlock-section">
					<button class="unlock-btn" id="unlock-btn">Unlock</button>
					<div class="unlock-input-wrapper" id="unlock-input-wrapper" style="display:none;">
						<input type="password" class="unlock-input" id="unlock-input" placeholder="Enter password..." />
						<button class="unlock-submit" id="unlock-submit">Go</button>
					</div>
					<p class="unlock-msg" id="unlock-msg"></p>
				</div>
			</div>
		</div>

		<!-- Rewards Modal -->
		<div class="wheel-overlay" id="rewards-overlay">
			<div class="wheel-modal">
				<button class="wheel-close" id="rewards-close">&times;</button>
				<h2 class="wheel-title">Your Rewards</h2>
				<div id="rewards-list" class="rewards-list"></div>
				<p class="rewards-empty" id="rewards-empty">No rewards yet. Spin the wheel to earn some!</p>
			</div>
		</div>

		<main>
			<slot />
		</main>

		<footer>
			<!-- Floating decorations -->
			<img src="/heart-pink.png" alt="" class="footer-deco fd-heart1" aria-hidden="true" />
			<img src="/heart-pink.png" alt="" class="footer-deco fd-heart2" aria-hidden="true" />
			<img src="/heart-pink.png" alt="" class="footer-deco fd-heart3" aria-hidden="true" />
			<img src="/heart-pink.png" alt="" class="footer-deco fd-heart4" aria-hidden="true" />
			<img src="/sparkle-pink.png" alt="" class="footer-deco fd-sparkle1" aria-hidden="true" />
			<img src="/sparkle-pink.png" alt="" class="footer-deco fd-sparkle2" aria-hidden="true" />
			<img src="/sparkle-pink.png" alt="" class="footer-deco fd-sparkle3" aria-hidden="true" />
			<img src="/sparkle-pink.png" alt="" class="footer-deco fd-sparkle4" aria-hidden="true" />
			<img src="/sakura-flower.png" alt="" class="footer-deco fd-flower1" aria-hidden="true" />
			<img src="/sakura-flower.png" alt="" class="footer-deco fd-flower2" aria-hidden="true" />
			<div class="footer-inner">
				<div class="footer-brand">
					<img src="/japanezy-logo-v2.png" alt="Japanezy Arts" class="footer-logo" />
					<p class="footer-tagline">A kawaii art world filled with love, creativity, and cute little paws.</p>
				</div>
				<div class="footer-links">
					<div class="footer-col">
						<h4>Explore</h4>
						<a href="/">Home</a>
						<a href="/puchipaws">PuchiPaws</a>
						<a href="/shop">Shop</a>
						<a href="/shorts">Videos</a>
					</div>
					<div class="footer-col">
						<h4>Fun Stuff</h4>
						<a href="/printable">Free Printables</a>
						<a href="/fan-art">Send Fan Art</a>
						<a href="/sticker-book-game">Sticker Game</a>
					</div>
					<div class="footer-col">
						<h4>Connect</h4>
						<a href="https://www.youtube.com/@JapanezyArts" target="_blank" rel="noopener">YouTube</a>
						<a href="#about">About</a>
					</div>
				</div>
			</div>
			<div class="footer-bottom">
				<p>Made with Love & Paws</p>
				<p>&copy; {new Date().getFullYear()} Japanezy Arts. All rights reserved.</p>
			</div>
		</footer>

		<script>
			const segments = [
				{ label: '10% Off', color: '#FFB3BA', textColor: '#333' },
				{ label: 'Try Again', color: '#BAE1FF', textColor: '#333' },
				{ label: 'Free Sticker', color: '#BAFFC9', textColor: '#333' },
				{ label: 'Bonus Gift', color: '#E8BAFF', textColor: '#333' },
				{ label: '50% Off', color: '#FFD700', textColor: '#e53935' },
			];

			const canvas = document.getElementById('wheel-canvas') as HTMLCanvasElement;
			const ctx = canvas?.getContext('2d');
			const overlay = document.getElementById('wheel-overlay');
			const openBtn = document.getElementById('open-wheel');
			const closeBtn = document.getElementById('wheel-close');
			const spinBtn = document.getElementById('spin-btn') as HTMLButtonElement;
			const resultEl = document.getElementById('wheel-result');

			const rewardsOverlay = document.getElementById('rewards-overlay');
			const rewardsOpenBtn = document.getElementById('open-rewards');
			const rewardsCloseBtn = document.getElementById('rewards-close');
			const rewardsList = document.getElementById('rewards-list');
			const rewardsEmpty = document.getElementById('rewards-empty');

			let currentAngle = 0;
			let spinning = false;

			function canSpin(): boolean {
				const lastSpin = localStorage.getItem('japanezy-last-spin');
				if (!lastSpin) return true;
				const diff = Date.now() - parseInt(lastSpin);
				const oneWeek = 7 * 24 * 60 * 60 * 1000;
				return diff >= oneWeek;
			}

			function getRewards(): { label: string; date: string }[] {
				return JSON.parse(localStorage.getItem('japanezy-rewards') || '[]');
			}

			function saveReward(label: string) {
				const rewards = getRewards();
				rewards.push({ label, date: new Date().toLocaleDateString() });
				localStorage.setItem('japanezy-rewards', JSON.stringify(rewards));
				localStorage.setItem('japanezy-last-spin', Date.now().toString());
			}

			function renderRewards() {
				const rewards = getRewards();
				if (!rewardsList || !rewardsEmpty) return;
				if (rewards.length === 0) {
					rewardsEmpty.style.display = 'block';
					rewardsList.innerHTML = '';
				} else {
					rewardsEmpty.style.display = 'none';
					rewardsList.innerHTML = rewards.map(r =>
						`<div class="reward-item"><span>${r.label}</span><span class="reward-date">${r.date}</span></div>`
					).join('');
				}
			}

			function checkSpinAvailability() {
				if (!canSpin() && spinBtn && resultEl) {
					spinBtn.setAttribute('disabled', '');
					resultEl.textContent = 'Sorry, you have to wait one week to spin this wheel again.';
				}
			}

			function drawWheel(angle: number) {
				if (!ctx) return;
				const cx = canvas.width / 2;
				const cy = canvas.height / 2;
				const r = cx - 5;
				const segAngle = (2 * Math.PI) / segments.length;

				ctx.clearRect(0, 0, canvas.width, canvas.height);

				segments.forEach((seg, i) => {
					const start = angle + i * segAngle;
					const end = start + segAngle;

					ctx.beginPath();
					ctx.moveTo(cx, cy);
					ctx.arc(cx, cy, r, start, end);
					ctx.closePath();
					ctx.fillStyle = seg.color;
					ctx.fill();
					ctx.strokeStyle = '#fff';
					ctx.lineWidth = 2;
					ctx.stroke();

					// Label
					ctx.save();
					ctx.translate(cx, cy);
					ctx.rotate(start + segAngle / 2);
					ctx.textAlign = 'right';
					ctx.fillStyle = seg.textColor;
					ctx.font = 'bold 14px Baloo 2, cursive';
					ctx.fillText(seg.label, r - 15, 5);
					ctx.restore();
				});

				// Center circle
				ctx.beginPath();
				ctx.arc(cx, cy, 18, 0, 2 * Math.PI);
				ctx.fillStyle = '#fff';
				ctx.fill();
				ctx.strokeStyle = '#ddd';
				ctx.lineWidth = 2;
				ctx.stroke();
			}

			const stopBtn = document.getElementById('stop-btn');
			let spinSpeed = 0;
			let stopping = false;
			let animFrameId: number | null = null;

			// Weighted random: pick which segment to land on
			// 50% Off = 5%, others = 23.75% each
			function pickWeightedSegment(): number {
				const r = Math.random() * 100;
				// segments: 0=10% Off, 1=Try Again, 2=Free Sticker, 3=Bonus Gift, 4=50% Off
				if (r < 23.75) return 0;
				if (r < 47.5) return 1;
				if (r < 71.25) return 2;
				if (r < 95) return 3;
				return 4; // 5% chance
			}

			function spinWheel() {
				if (spinning) return;
				if (!canSpin()) {
					if (resultEl) resultEl.textContent = 'Sorry, you have to wait one week to spin this wheel again.';
					return;
				}
				spinning = true;
				stopping = false;
				spinSpeed = 0.3 + Math.random() * 0.2; // fast random speed
				if (spinBtn) spinBtn.style.display = 'none';
				if (stopBtn) stopBtn.style.display = 'inline-block';
				if (resultEl) resultEl.textContent = '';

				function animate() {
					if (stopping) {
						spinSpeed *= 0.97; // decelerate
						if (spinSpeed < 0.001) {
							spinSpeed = 0;
							spinning = false;
							stopping = false;
							if (spinBtn) spinBtn.style.display = 'inline-block';
							if (stopBtn) stopBtn.style.display = 'none';

							// Determine winner
							const segAngle = (2 * Math.PI) / segments.length;
							const normalized = ((2 * Math.PI) - (currentAngle % (2 * Math.PI)) + (3 * Math.PI / 2)) % (2 * Math.PI);
							const index = Math.floor(normalized / segAngle) % segments.length;
							const winner = segments[index].label;

							if (winner === 'Try Again') {
								if (resultEl) {
									resultEl.textContent = 'Try Again! Spinning one more time...';
								}
								setTimeout(() => {
									spinWheel();
								}, 1500);
								return;
							}

							saveReward(winner);
							checkSpinAvailability();

							if (resultEl) {
								resultEl.textContent = `Congratulations! You landed on ${winner}!`;
							}
							return;
						}
					}

					currentAngle += spinSpeed;
					drawWheel(currentAngle);
					animFrameId = requestAnimationFrame(animate);
				}

				animFrameId = requestAnimationFrame(animate);
			}

			function stopWheel() {
				if (!spinning || stopping) return;
				stopping = true;

				// Weighted target: pick segment and nudge toward it
				const targetIdx = pickWeightedSegment();
				const segAngle = (2 * Math.PI) / segments.length;
				// Calculate target angle so arrow lands in the middle of that segment
				const targetCenter = segAngle * targetIdx + segAngle / 2;
				const targetAngle = (3 * Math.PI / 2) - targetCenter;
				// Normalize to add extra full rotations so it keeps going forward
				const extra = Math.ceil(spinSpeed * 80); // enough rotations to decelerate
				const finalAngle = targetAngle + extra * 2 * Math.PI;

				// Adjust currentAngle so deceleration lands near target
				const remaining = finalAngle - (currentAngle % (2 * Math.PI));
				currentAngle = currentAngle + (remaining > 0 ? remaining : remaining + 2 * Math.PI);
			}

			stopBtn?.addEventListener('click', stopWheel);

			// Draw initial wheel
			if (ctx) drawWheel(currentAngle);

			// Open/close modal
			openBtn?.addEventListener('click', () => overlay?.classList.add('open'));
			closeBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
			overlay?.addEventListener('click', (e) => {
				if (e.target === overlay) overlay.classList.remove('open');
			});

			// Spin
			spinBtn?.addEventListener('click', spinWheel);

			// Rewards modal
			rewardsOpenBtn?.addEventListener('click', () => { renderRewards(); rewardsOverlay?.classList.add('open'); });
			rewardsCloseBtn?.addEventListener('click', () => rewardsOverlay?.classList.remove('open'));
			rewardsOverlay?.addEventListener('click', (e) => {
				if (e.target === rewardsOverlay) rewardsOverlay.classList.remove('open');
			});

			// Unlock button
			const unlockBtn = document.getElementById('unlock-btn');
			const unlockWrapper = document.getElementById('unlock-input-wrapper');
			const unlockInput = document.getElementById('unlock-input') as HTMLInputElement;
			const unlockSubmit = document.getElementById('unlock-submit');
			const unlockMsg = document.getElementById('unlock-msg');

			unlockBtn?.addEventListener('click', () => {
				unlockWrapper!.style.display = unlockWrapper!.style.display === 'none' ? 'flex' : 'none';
				if (unlockMsg) unlockMsg.textContent = '';
			});

			unlockSubmit?.addEventListener('click', () => {
				if (unlockInput?.value === 'roseyblackwhiteburt') {
					localStorage.removeItem('japanezy-last-spin');
					if (spinBtn) spinBtn.removeAttribute('disabled');
					if (resultEl) resultEl.textContent = '';
					if (unlockMsg) {
						unlockMsg.textContent = 'Wheel unlocked!';
						unlockMsg.style.color = '#4caf50';
					}
					unlockWrapper!.style.display = 'none';
					unlockInput.value = '';
				} else {
					if (unlockMsg) {
						unlockMsg.textContent = 'Wrong password.';
						unlockMsg.style.color = '#e53935';
					}
				}
			});

			unlockInput?.addEventListener('keydown', (e) => {
				if (e.key === 'Enter') unlockSubmit?.click();
			});

			// Remove any "Try Again" entries from saved rewards
			const currentRewards = getRewards();
			const filtered = currentRewards.filter(r => r.label !== 'Try Again');
			if (filtered.length !== currentRewards.length) {
				localStorage.setItem('japanezy-rewards', JSON.stringify(filtered));
			}

			// Check if they can spin on load
			checkSpinAvailability();

			// Hamburger menu toggle
			const hamburger = document.getElementById('hamburger');
			const navLinks = document.getElementById('nav-links');
			hamburger?.addEventListener('click', () => {
				navLinks?.classList.toggle('open');
				hamburger.classList.toggle('open');
			});
			// Close menu when a nav link is clicked
			navLinks?.querySelectorAll('a, button').forEach(link => {
				link.addEventListener('click', () => {
					navLinks.classList.remove('open');
					hamburger?.classList.remove('open');
				});
			});

		</script>
	</body>
</html>

<style is:global>
	/* Footer decorations */
	.footer-deco {
		position: absolute;
		pointer-events: none;
		z-index: 0;
	}
	.fd-heart1 { width: 40px; left: 5%; top: 12%; opacity: 0.85; transform: rotate(-12deg); }
	.fd-heart2 { width: 30px; right: 8%; top: 18%; opacity: 0.75; transform: rotate(15deg); }
	.fd-heart3 { width: 25px; left: 45%; bottom: 20%; opacity: 0.65; transform: rotate(-8deg); }
	.fd-heart4 { width: 35px; right: 25%; bottom: 12%; opacity: 0.7; transform: rotate(10deg); }
	.fd-sparkle1 { width: 50px; right: 15%; top: 8%; opacity: 0.8; }
	.fd-sparkle2 { width: 40px; left: 20%; bottom: 15%; opacity: 0.7; }
	.fd-sparkle3 { width: 35px; right: 40%; top: 35%; opacity: 0.6; }
	.fd-sparkle4 { width: 45px; left: 60%; top: 6%; opacity: 0.75; }
	.fd-flower1 { width: 30px; left: 12%; top: 45%; opacity: 0.75; }
	.fd-flower2 { width: 25px; right: 6%; bottom: 25%; opacity: 0.65; }

	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Nunito', 'Baloo 2', sans-serif;
		background-color: #FFF9F7;
		color: #1a1a1a;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		position: relative;
		overflow-x: hidden;
	}

	main {
		flex: 1;
	}

	h1, h2, h3, h4 {
		font-family: 'Baloo 2', cursive;
		font-weight: 800;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	/* Floating hearts and stars */
	.decorations {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.decorations .blossom,
	.decorations .paw {
		position: absolute;
		font-size: 2rem;
		opacity: 0.4;
		animation: float 12s ease-in-out infinite;
	}

	.decorations .blossom {
		filter: none;
	}

	.decorations .paw {
		filter: none;
		opacity: 0.3;
	}

	.decorations span:nth-child(1)  { top: 3%;  left: 5%;  font-size: 2.2rem; animation-delay: 0s; }
	.decorations span:nth-child(2)  { top: 8%;  left: 25%; font-size: 1.6rem; animation-delay: 1.5s; }
	.decorations span:nth-child(3)  { top: 12%; left: 70%; font-size: 2.5rem; animation-delay: 3s; }
	.decorations span:nth-child(4)  { top: 20%; left: 90%; font-size: 1.4rem; animation-delay: 4.5s; }
	.decorations span:nth-child(5)  { top: 30%; left: 8%;  font-size: 1.8rem; animation-delay: 2s; }
	.decorations span:nth-child(6)  { top: 35%; left: 50%; font-size: 2.3rem; animation-delay: 5s; }
	.decorations span:nth-child(7)  { top: 45%; left: 85%; font-size: 1.5rem; animation-delay: 1s; }
	.decorations span:nth-child(8)  { top: 55%; left: 15%; font-size: 2rem;   animation-delay: 3.5s; }
	.decorations span:nth-child(9)  { top: 60%; left: 65%; font-size: 1.7rem; animation-delay: 6s; }
	.decorations span:nth-child(10) { top: 70%; left: 40%; font-size: 2.4rem; animation-delay: 2.5s; }
	.decorations span:nth-child(11) { top: 78%; left: 78%; font-size: 1.6rem; animation-delay: 4s; }
	.decorations span:nth-child(12) { top: 82%; left: 3%;  font-size: 2.1rem; animation-delay: 0.5s; }
	.decorations span:nth-child(13) { top: 88%; left: 55%; font-size: 1.9rem; animation-delay: 5.5s; }
	.decorations span:nth-child(14) { top: 92%; left: 30%; font-size: 1.5rem; animation-delay: 7s; }
	.decorations span:nth-child(15) { top: 15%; left: 45%; font-size: 2rem;   animation-delay: 3s; }
	.decorations span:nth-child(16) { top: 50%; left: 35%; font-size: 1.8rem; animation-delay: 1.5s; }

	@keyframes float {
		0%, 100% { transform: translateY(0) rotate(0deg); }
		25% { transform: translateY(-15px) rotate(5deg); }
		50% { transform: translateY(-25px) rotate(-3deg); }
		75% { transform: translateY(-10px) rotate(4deg); }
	}

	/* Nav */
	.nav {
		display: flex;
		align-items: center;
		padding: 0.8rem 1.2rem 0.8rem 0;
		background: rgba(255, 255, 255, 0.75);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		position: sticky;
		top: 12px;
		z-index: 100;
		box-shadow: 0 2px 16px rgba(107, 62, 46, 0.1);
		border-radius: 16px;
		max-width: 1100px;
		margin: 0 auto 0;
		width: 100%;
		gap: 0;
	}

	.nav-logo-link {
		display: flex;
		align-items: center;
		flex-shrink: 0;
		margin-right: auto;
		align-self: stretch;
		position: relative;
	}

	.nav-logo {
		height: 144px;
		width: auto;
		margin-top: -37px;
		margin-bottom: -73px;
		margin-left: 4px;
		filter: drop-shadow(0 2px 6px rgba(107, 62, 46, 0.1));
		position: relative;
		z-index: 2;
	}

	.nav-links {
		display: flex;
		gap: 0.25rem;
		align-items: center;
		flex: 1;
		justify-content: center;
	}

	.nav-paw {
		display: flex;
		align-items: center;
		opacity: 0.6;
	}
	.nav-paw img {
		filter: invert(73%) sepia(30%) saturate(1000%) hue-rotate(300deg) brightness(100%) contrast(95%);
	}

	.nav-link {
		font-family: 'Nunito', sans-serif;
		font-size: 0.85rem;
		font-weight: 700;
		color: #6B3E2E;
		padding: 0.4rem 0.75rem;
		border-radius: 8px;
		transition: all 0.2s;
		white-space: nowrap;
		flex: 1;
		text-align: center;
	}

	.nav-link:hover {
		color: #FF9BB7;
		background: rgba(255, 155, 183, 0.08);
	}

	.nav-cta {
		display: inline-flex;
		align-items: center;
		background: #FF9BB7;
		color: #fff;
		font-family: 'Baloo 2', cursive;
		font-size: 0.85rem;
		font-weight: 700;
		padding: 0.5rem 1.25rem;
		border-radius: 10px;
		margin-left: auto;
		transition: all 0.2s;
		white-space: nowrap;
		box-shadow: 0 2px 8px rgba(255, 155, 183, 0.3);
