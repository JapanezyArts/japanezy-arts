---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Request a Shoutout - Japanezy Arts">
	<section class="shoutout-section">
		<a href="/" class="close-btn" aria-label="Back to home">&times;</a>
		<h2>Request a Shoutout</h2>
		<p class="shoutout-subtitle">Enter your YouTube username and I'll give you a shoutout!</p>
		<form action="https://formsubmit.co/scarlettsburt@icloud.com" method="POST" class="shoutout-form">
			<input type="hidden" name="_subject" value="New Shoutout Request from Japanezy Arts!" />
			<input type="hidden" name="_captcha" value="false" />
			<input type="hidden" name="_next" value="http://localhost:4321/shoutout-thanks" />
			<input type="text" name="youtube-username" placeholder="Your YouTube username" required class="shoutout-input" />
			<button type="submit" class="btn shoutout-submit">Send</button>
		</form>
	</section>
</Layout>

<style>
	.close-btn {
		position: absolute;
		top: 0.75rem;
		left: 0.75rem;
		width: 40px;
		height: 40px;
		background: #fff;
		border: 2px solid #ddd;
		border-radius: 50%;
		font-size: 1.5rem;
		line-height: 36px;
		text-align: center;
		color: #666;
		text-decoration: none;
		z-index: 10;
		transition: all 0.2s;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}

	.close-btn:hover {
		background: #F2A6B5;
		color: #fff;
		border-color: #F2A6B5;
	}

	.shoutout-section {
		padding: 4rem 2rem;
		text-align: center;
		position: relative;
		z-index: 1;
		max-width: 500px;
		margin: 0 auto;
	}

	.shoutout-section h2 {
		font-size: 2.25rem;
		color: #D4816B;
		margin-bottom: 0.5rem;
	}

	.shoutout-subtitle {
		color: #666;
		margin-bottom: 2rem;
		font-size: 1.1rem;
	}

	.shoutout-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.shoutout-input {
		width: 100%;
		max-width: 350px;
		padding: 0.85rem 1rem;
		border: 2px solid #FCE4D8;
		border-radius: 8px;
		font-size: 1rem;
		font-family: 'Baloo 2', cursive;
		outline: none;
		transition: border-color 0.2s;
	}

	.shoutout-input:focus {
		border-color: #D4816B;
	}

	.shoutout-submit {
		background: #E8879B;
		color: #fff;
		padding: 0.85rem 2.5rem;
		border: none;
		cursor: pointer;
		font-family: 'Baloo 2', cursive;
		font-size: 1rem;
		font-weight: 600;
		border-radius: 6px;
		transition: background 0.2s;
	}

	.shoutout-submit:hover {
		background: #D4706A;
	}

	@media (max-width: 768px) {
		.shoutout-section {
			padding: 2.5rem 1rem;
		}

		.shoutout-section h2 {
			font-size: 1.75rem;
		}

		.shoutout-subtitle {
			font-size: 1rem;
		}

		.shoutout-submit {
			width: 100%;
			max-width: 350px;
			box-sizing: border-box;
		}
	}

	@media (max-width: 480px) {
		.shoutout-section {
			padding: 2rem 1rem;
		}

		.shoutout-section h2 {
			font-size: 1.5rem;
		}
	}
</style>
