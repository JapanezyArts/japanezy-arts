---
import Layout from '../layouts/Layout.astro';

const shorts = [
	{ id: "6Yh_F6ueRrE", title: "Newest Short" },
	{ id: "Tyj072FLmNQ", title: "Organize Ohuhu Markers" },
	{ id: "IkdRY_1paiY", title: "ASMR Paper Squishy" },
	{ id: "H9v6v6uYkgA", title: "Drawing Cinema Roll" },
	{ id: "ZRXtO5RUVwI", title: "Comment for Me to Draw Profile Pictures" },
	{ id: "Ve-eHDKadEo", title: "Oh My God, No Way" },
	{ id: "UB7ikEJzttU", title: "Request From" },
	{ id: "SeZe6MMI2Z4", title: "Cute Drawing for Beginners" },
	{ id: "YYe-m5HE0h0", title: "Velokuma Paper Squishy" },
	{ id: "3JjOc7XHnGM", title: "Can I Draw That?" },
	{ id: "K-bu-cRQISk", title: "I Drew UG" },
];
---

<Layout title="Top Shorts - Japanezy Arts">
	<section class="shorts-section">
		<a href="/" class="close-btn" aria-label="Back to home">&times;</a>
		<div class="shorts-header">
			<h2 id="shorts-title">Top Shorts</h2>
			<button class="btn newest-btn" id="newest-btn">Newest Short</button>
		</div>

		<!-- Newest Short -->
		<div class="newest-short" id="newest-short" style="display: none;">
			<a href="https://youtube.com/shorts/6Yh_F6ueRrE" target="_blank" rel="noopener" class="newest-link">
				<div class="short-card newest-card">
					<img src="https://i.ytimg.com/vi/6Yh_F6ueRrE/oar2.jpg" alt="Newest Short" class="newest-thumb" />
					<div class="play-overlay">
						<div class="play-icon">&#9654;</div>
					</div>
				</div>
			</a>
			<button class="btn back-btn" id="back-btn">Back to Top Shorts</button>
		</div>

		<div class="shorts-grid" id="shorts-grid">
			{shorts.map((short) => (
				<a href={`https://youtube.com/shorts/${short.id}`} target="_blank" rel="noopener" class="short-card">
					<img src={`https://i.ytimg.com/vi/${short.id}/oar2.jpg`} alt={short.title} class="short-thumb" />
					<div class="play-overlay">
						<div class="play-icon">&#9654;</div>
					</div>
				</a>
			))}
		</div>
	</section>
</Layout>

<style>
	.close-btn {
		position: absolute;
		top: 0.75rem;
		left: 0.75rem;
		width: 40px;
		height: 40px;
		background: #fff;
		border: 2px solid #ddd;
		border-radius: 50%;
		font-size: 1.5rem;
		line-height: 36px;
		text-align: center;
		color: #666;
		text-decoration: none;
		z-index: 10;
		transition: all 0.2s;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}

	.close-btn:hover {
		background: #f8bbd0;
		color: #fff;
		border-color: #f8bbd0;
	}

	.shorts-section {
		padding: 3rem 2rem 4rem;
		text-align: center;
		position: relative;
		z-index: 1;
		max-width: 1200px;
		margin: 0 auto;
	}

	.shorts-header {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.shorts-section h2 {
		font-size: 2.25rem;
		color: #7baed4;
		margin: 0;
	}

	.newest-btn {
		background: #d5b3f5;
		color: #fff;
		padding: 0.6rem 1.5rem;
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.9rem;
		border-radius: 6px;
		transition: background 0.2s;
	}

	.newest-btn:hover {
		background: #c9a3eb;
	}

	.newest-short {
		max-width: 450px;
		margin: 0 auto 2rem;
	}

	.newest-link {
		display: block;
		text-decoration: none;
	}

	.newest-card {
		margin-bottom: 1.5rem;
		position: relative;
	}

	.newest-thumb {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.play-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.2);
		transition: background 0.2s;
	}

	.newest-link:hover .play-overlay {
		background: rgba(0, 0, 0, 0.35);
	}

	.play-icon {
		width: 60px;
		height: 60px;
		background: rgba(255, 255, 255, 0.9);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
		color: #e53935;
		padding-left: 4px;
	}

	.back-btn {
		background: #7baed4;
		color: #fff;
		padding: 0.6rem 1.5rem;
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.9rem;
		border-radius: 6px;
		transition: background 0.2s;
	}

	.back-btn:hover {
		background: #6a9dc4;
	}

	.shorts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 1.5rem;
	}

	.short-card {
		background: #fff;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 16px rgba(155, 89, 182, 0.15);
		aspect-ratio: 9 / 16;
	}

	.short-card {
		display: block;
		text-decoration: none;
		position: relative;
	}

	.short-thumb {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.short-card .play-overlay {
		opacity: 0;
		transition: opacity 0.2s;
	}

	.short-card:hover .play-overlay {
		opacity: 1;
	}

	@media (max-width: 768px) {
		.shorts-section {
			padding: 2rem 1rem 3rem;
		}

		.shorts-section h2 {
			font-size: 1.75rem;
		}

		.shorts-grid {
			grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
			gap: 1rem;
		}
	}
</style>

<script>
	const newestBtn = document.getElementById('newest-btn');
	const backBtn = document.getElementById('back-btn');
	const newestShort = document.getElementById('newest-short');
	const shortsGrid = document.getElementById('shorts-grid');
	const shortsTitle = document.getElementById('shorts-title');

	newestBtn?.addEventListener('click', () => {
		newestShort!.style.display = 'block';
		shortsGrid!.style.display = 'none';
		newestBtn!.style.display = 'none';
		shortsTitle!.textContent = 'Newest Short';
	});

	backBtn?.addEventListener('click', () => {
		newestShort!.style.display = 'none';
		shortsGrid!.style.display = 'grid';
		newestBtn!.style.display = 'inline-block';
		shortsTitle!.textContent = 'Top Shorts';
	});
</script>
