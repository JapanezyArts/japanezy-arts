---
import Layout from '../layouts/Layout.astro';

// Add / remove / reorder pieces here — each becomes a post in the feed.
const artworks = [
	{ src: "/art-chikawa.jpg", title: "Chikawa" },
	{ src: "/art-suzu.jpg", title: "Suzu" },
	{ src: "/art-capybara.jpg", title: "Watermelon Capybara" },
	{ src: "/art-water.jpg", title: "Sparkling Ice Water" },
	{ src: "/art-cake.jpg", title: "Strawberry Shortcake" },
	{ src: "/art-catpaw.jpg", title: "CatPaw Gummies" },
	{ src: "/art-picnic.jpg", title: "Picnic by Mount Fuji" },
	{ src: "/art-hamster.jpg", title: "Hamster" },
	{ src: "/art-mew.jpg", title: "Mew & Teddy" },
	{ src: "/art-mewpikachu.jpg", title: "Mew & Pikachu" },
	{ src: "/art-noob.jpg", title: "Roblox Noob" },
	{ src: "/art-petdango.jpg", title: "Pet Dango" },
	{ src: "/art-pika.jpg", title: "Pikachu" },
	{ src: "/art-saki-art.jpg", title: "Saki" },
	{ src: "/art-boba.jpg", title: "Sparkly Boba Tea" },
];
---

<Layout title="Art - Japanezy Arts">
	<section class="ig">
		<div class="ak-toprow">
			<a href="/artkai" class="artkai-launch">
				<span class="artkai-x" aria-hidden="true">♥</span>
				<span class="artkai-launch-label">Go to Artkai</span>
			</a>
			<button class="secret-btn" id="secret-btn"><span aria-hidden="true">🤫</span> Secret Video</button>
		</div>

		<!-- Profile header -->
		<header class="ig-profile">
			<div class="ig-avatar">
				<img src="/rosey.png" alt="Japanezy Arts" />
			</div>
			<div class="ig-meta">
				<div class="ig-top">
					<h1 class="ig-handle">@japanezyarts</h1>
				</div>
				<div class="ig-stats">
					<span><strong>{artworks.length}</strong> posts</span>
					<span><strong>Kawaii</strong> vibes</span>
					<span><strong>∞</strong> cuteness</span>
				</div>
				<p class="ig-bio"><strong>Japanezy Arts 🎨🐾</strong><br/>Tap any piece to save it — use it as your profile picture!</p>
			</div>
		</header>

		<!-- Feed grid -->
		<div class="ig-grid">
			{artworks.map((art, i) => (
				<button class="ig-post" data-src={art.src} data-title={art.title} aria-label={`Open ${art.title}`}>
					<img src={art.src} alt={art.title} loading={i < 6 ? "eager" : "lazy"} />
					<span class="ig-post-overlay">
						<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
						<span>View</span>
					</span>
				</button>
			))}
		</div>
	</section>

	<!-- Lightbox / viewer -->
	<div class="lb-overlay" id="lb-overlay" role="dialog" aria-modal="true">
		<div class="lb-modal">
			<button class="lb-close" id="lb-close" aria-label="Close">&times;</button>
			<div class="lb-img-wrap">
				<img id="lb-img" src="" alt="" />
			</div>
			<p class="lb-title" id="lb-title"></p>
			<p class="lb-instruction"><img src="/paw-icon.svg" alt="" class="lb-paw" /> Right click to save, or press &amp; hold to save</p>
			<p class="lb-hint">Then use it as your profile picture!</p>
		</div>
	</div>

	<!-- Secret video popup -->
	<div class="video-overlay" id="video-overlay" role="dialog" aria-modal="true">
		<div class="video-modal">
			<button class="video-close" id="video-close" aria-label="Close">&times;</button>
			<div class="video-frame">
				<iframe id="secret-iframe" src="" title="Secret Video" allow="autoplay; encrypted-media; picture-in-picture; fullscreen" allowfullscreen></iframe>
			</div>
		</div>
	</div>
</Layout>

<style>
	.ig {
		max-width: 935px;
		margin: 0 auto;
		padding: 3rem 1.25rem 5rem;
		position: relative;
	}

	.ak-toprow {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.artkai-launch {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		gap: 0.45rem;
		text-decoration: none;
	}

	.artkai-x {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 66px;
		height: 66px;
		background: linear-gradient(135deg, #FF9BB7, #c48daa);
		color: #fff;
		font-size: 2.1rem;
		font-weight: 800;
		font-family: 'Baloo 2', cursive;
		border-radius: 20px;
		box-shadow: 0 6px 18px rgba(255, 155, 183, 0.5);
		transition: transform 0.15s;
	}

	.artkai-launch:hover .artkai-x { transform: translateY(-3px) rotate(-6deg); }

	.artkai-launch-label {
		font-family: 'Baloo 2', cursive;
		font-weight: 700;
		color: #d96c85;
		font-size: 0.9rem;
	}

	.secret-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: linear-gradient(135deg, #c48daa, #FF9BB7);
		color: #fff;
		font-family: 'Baloo 2', cursive;
		font-weight: 700;
		font-size: 0.9rem;
		padding: 0.55rem 1.1rem;
		border: none;
		border-radius: 999px;
		cursor: pointer;
		box-shadow: 0 4px 14px rgba(196, 141, 170, 0.45);
		transition: transform 0.15s, box-shadow 0.15s;
	}

	.secret-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 18px rgba(196, 141, 170, 0.55);
	}

	.video-overlay {
		position: fixed;
		inset: 0;
		background: rgba(30, 15, 20, 0.8);
		backdrop-filter: blur(3px);
		display: none;
		align-items: center;
		justify-content: center;
		z-index: 1100;
		padding: 1.5rem;
	}

	.video-overlay.open { display: flex; }

	.video-modal {
		position: relative;
		width: min(880px, 100%);
	}

	.video-frame {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		border-radius: 16px;
		overflow: hidden;
		background: #000;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
	}

	.video-frame iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	.video-close {
		position: absolute;
		top: -2.75rem;
		right: 0;
		background: none;
		border: none;
		color: #fff;
		font-size: 2rem;
		line-height: 1;
		cursor: pointer;
	}

	/* ===== Profile header ===== */
	.ig-profile {
		display: flex;
		align-items: center;
		gap: clamp(1.5rem, 6vw, 5rem);
		padding: 0 1rem 2.5rem;
		border-bottom: 1px solid #f3d9e2;
		margin-bottom: 2rem;
	}

	.ig-avatar {
		flex: 0 0 auto;
		width: clamp(90px, 20vw, 150px);
		height: clamp(90px, 20vw, 150px);
		border-radius: 50%;
		overflow: hidden;
		background: #ffe6ec;
		border: 4px solid #FF9BB7;
	}

	.ig-avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 22%;
	}

	.ig-meta {
		flex: 1;
		min-width: 0;
	}

	.ig-handle {
		font-size: clamp(1.3rem, 3vw, 1.9rem);
		color: #6B3E2E;
		font-weight: 700;
		margin-bottom: 1rem;
	}

	.ig-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		margin-bottom: 1rem;
		color: #6B3E2E;
		font-size: 0.95rem;
	}

	.ig-stats strong { color: #d96c85; }

	.ig-bio {
		color: #5f5560;
		line-height: 1.6;
		font-size: 0.95rem;
	}

	/* ===== Feed grid ===== */
	.ig-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 6px;
	}

	.ig-post {
		position: relative;
		aspect-ratio: 1 / 1;
		border: none;
		padding: 0;
		cursor: pointer;
		background: #fff0f5;
		overflow: hidden;
		border-radius: 4px;
	}

	.ig-post img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.25s;
	}

	.ig-post:hover img { transform: scale(1.05); }

	.ig-post-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.3rem;
		background: rgba(216, 108, 133, 0.55);
		color: #fff;
		font-weight: 700;
		font-size: 0.9rem;
		opacity: 0;
		transition: opacity 0.2s;
	}

	.ig-post:hover .ig-post-overlay,
	.ig-post:focus-visible .ig-post-overlay { opacity: 1; }

	/* ===== Lightbox ===== */
	.lb-overlay {
		position: fixed;
		inset: 0;
		background: rgba(60, 30, 40, 0.6);
		backdrop-filter: blur(3px);
		display: none;
		align-items: center;
		justify-content: center;
		z-index: 1000;
		padding: 1.5rem;
	}

	.lb-overlay.open { display: flex; }

	.lb-modal {
		background: #fff;
		border-radius: 22px;
		padding: 1.75rem;
		max-width: 420px;
		width: 100%;
		text-align: center;
		position: relative;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
	}

	.lb-close {
		position: absolute;
		top: 0.75rem;
		right: 0.9rem;
		background: none;
		border: none;
		font-size: 1.9rem;
		line-height: 1;
		color: #c48daa;
		cursor: pointer;
	}

	.lb-img-wrap {
		background: #fff0f5;
		border-radius: 16px;
		padding: 1.25rem;
		margin-bottom: 1rem;
	}

	.lb-img-wrap img {
		max-width: 100%;
		max-height: 46vh;
		object-fit: contain;
		display: block;
		margin: 0 auto;
	}

	.lb-title {
		font-weight: 700;
		color: #d96c85;
		font-size: 1.15rem;
		margin-bottom: 0.35rem;
	}

	.lb-instruction {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: #FF9BB7;
		color: #fff;
		font-family: 'Baloo 2', cursive;
		font-weight: 700;
		font-size: 0.95rem;
		padding: 0.65rem 1.4rem;
		border-radius: 12px;
		box-shadow: 0 4px 14px rgba(255, 155, 183, 0.4);
		margin-bottom: 0.75rem;
	}

	.lb-instruction .lb-paw { filter: brightness(0) invert(1); }

	.lb-hint {
		color: #7a6b74;
		font-size: 0.9rem;
		margin: 0;
	}

	.lb-paw { width: 15px; height: 15px; vertical-align: -2px; }

	@media (max-width: 768px) {
		.ig { padding: 2rem 0.75rem 4rem; }

		.ak-toprow {
			gap: 0.75rem;
			margin-bottom: 1.25rem;
		}

		.artkai-x {
			width: 56px;
			height: 56px;
			font-size: 1.8rem;
			border-radius: 16px;
		}

		.artkai-launch-label { font-size: 0.8rem; }

		.secret-btn {
			font-size: 0.82rem;
			padding: 0.5rem 0.9rem;
		}

		.ig-profile {
			flex-direction: column;
			text-align: center;
			gap: 1.25rem;
			padding: 0 0.5rem 1.75rem;
		}

		.ig-avatar { width: 96px; height: 96px; }

		.ig-stats { justify-content: center; gap: 1rem; }

		.ig-grid { gap: 4px; }

		.video-close { top: -2.5rem; right: 0.25rem; }
	}

	@media (max-width: 480px) {
		.artkai-x {
			width: 48px;
			height: 48px;
			font-size: 1.5rem;
		}

		.artkai-launch-label { font-size: 0.72rem; }

		.secret-btn {
			font-size: 0.75rem;
			padding: 0.45rem 0.7rem;
			gap: 0.25rem;
		}

		.lb-overlay { padding: 1rem; }

		.lb-modal { padding: 1.25rem; }

		.lb-img-wrap { padding: 0.9rem; }

		.lb-img-wrap img { max-height: 42vh; }

		.lb-instruction {
			font-size: 0.85rem;
			padding: 0.6rem 1rem;
		}

		.video-overlay { padding: 1rem; }
	}
</style>

<script>
	const overlay = document.getElementById('lb-overlay');
	const lbImg = document.getElementById('lb-img') as HTMLImageElement;
	const lbTitle = document.getElementById('lb-title');

	document.querySelectorAll('.ig-post').forEach((btn) => {
		btn.addEventListener('click', () => {
			const src = btn.getAttribute('data-src') || '';
			const title = btn.getAttribute('data-title') || 'Japanezy Arts';
			if (lbImg) { lbImg.src = src; lbImg.alt = title; }
			if (lbTitle) lbTitle.textContent = title;
			overlay?.classList.add('open');
		});
	});

	function closeLb() { overlay?.classList.remove('open'); }
	document.getElementById('lb-close')?.addEventListener('click', closeLb);
	overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeLb(); });

	// Secret video
	const videoOverlay = document.getElementById('video-overlay');
	const videoIframe = document.getElementById('secret-iframe') as HTMLIFrameElement;
	const SECRET_EMBED = 'https://www.youtube.com/embed/kqlBr6-f6_Y?autoplay=1&rel=0';

	document.getElementById('secret-btn')?.addEventListener('click', () => {
		if (videoIframe) videoIframe.src = SECRET_EMBED;
		videoOverlay?.classList.add('open');
	});

	function closeVideo() {
		videoOverlay?.classList.remove('open');
		if (videoIframe) videoIframe.src = '';
	}
	document.getElementById('video-close')?.addEventListener('click', closeVideo);
	videoOverlay?.addEventListener('click', (e) => { if (e.target === videoOverlay) closeVideo(); });

	document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeLb(); closeVideo(); } });
</script>
