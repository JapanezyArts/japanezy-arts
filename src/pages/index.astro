---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products';
---

<Layout title="Japanezy Arts - Home">
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-text">
				<h1>
					<span class="hero-line1">Welcome to the</span><br/>
					<span class="hero-line2">cozy world of</span><br/>
					<span class="hero-line3">Japanezy </span><span class="hero-line4">Arts</span>
				</h1>
				<p class="hero-sub">Meet Saki, Suzu, and Chizuro, download cute freebies, shop kawaii goodies, and follow along with our art adventures from YouTube.</p>
				<div class="hero-btns">
					<a href="/printable" class="btn btn-sakura"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:6px"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Get Free Downloads</a>
					<a href="/puchipaws" class="btn btn-outline-pink"><img src="/paw-icon.svg" alt="" width="14" height="14" style="vertical-align:-2px;margin-right:6px;filter:invert(73%) sepia(30%) saturate(1000%) hue-rotate(300deg) brightness(100%) contrast(95%);" />Meet the PuchiPaws</a>
				</div>
			</div>
			<div class="hero-right">
				<img src="/japanezy-logo-v2.png" alt="Japanezy Arts" class="hero-logo" />
				<div class="hc-row">
					<img src="/rosey-hero.png" alt="Rosey" class="hc-rosey" />
					<img src="/puchipaws-hero.png" alt="PuchiPaws - Suzu, Saki, and Chizuro" class="hc-group" />
				</div>
			</div>
		</div>
	</section>

	<!-- YouTube Companion -->
	<section class="yt-companion">
		<div class="yt-companion-inner">
			<div class="yt-companion-left">
				<img src="/yt-play-pink.png" alt="YouTube" class="yt-badge-img" />
				<div>
					<h3 class="yt-companion-title">Here from YouTube?<br/>Start here.</h3>
					<p class="yt-companion-sub">Grab the extras from our latest videos, including printables, sticker sheets, wallpapers, and behind-the-scenes goodies.</p>
					<a href="https://www.youtube.com/@JapanezyArts?sub_confirmation=1" target="_blank" rel="noopener" class="yt-sub-link">Subscribe on YouTube &rarr;</a>
				</div>
			</div>
			<a href="/printable" class="yt-comp-card">
				<img src="/freebie-library.png" alt="Freebie Library" />
				<span class="yt-comp-title">Freebie Library</span>
				<span class="yt-comp-bottom">
					<span class="yt-comp-sub">Printables, activity sheets, checklists, and more!</span>
					<span class="yt-comp-arrow"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#FF9BB7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
				</span>
			</a>
			<a href="/coloring" class="yt-comp-card">
				<img src="/coloring-pages.png" alt="Coloring Pages" />
				<span class="yt-comp-title">Coloring Pages</span>
				<span class="yt-comp-bottom">
					<span class="yt-comp-sub">Adorable pages to color and enjoy.</span>
					<span class="yt-comp-arrow"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#FF9BB7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
				</span>
			</a>
			<a href="/fan-art" class="yt-comp-card">
				<img src="/art-prompts.png" alt="Art Prompts" />
				<span class="yt-comp-title">Art Prompts</span>
				<span class="yt-comp-bottom">
					<span class="yt-comp-sub">Fun prompts to spark your creativity.</span>
					<span class="yt-comp-arrow"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#FF9BB7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
				</span>
			</a>
			<a href="/wallpapers" class="yt-comp-card">
				<img src="/wallpapers.png" alt="Wallpapers" />
				<span class="yt-comp-title">Wallpapers</span>
				<span class="yt-comp-bottom">
					<span class="yt-comp-sub">Cute backgrounds for your devices.</span>
					<span class="yt-comp-arrow"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#FF9BB7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
				</span>
			</a>
		</div>

		<!-- Free Wallpapers Promo Bar -->
		<div class="signup-bar-inner">
			<!-- Floating decorations -->
			<img src="/sparkle-pink.png" alt="" class="signup-deco deco-sparkle1" aria-hidden="true" />
			<img src="/sparkle-pink.png" alt="" class="signup-deco deco-sparkle2" aria-hidden="true" />
			<div class="signup-char">
				<img src="/roseypeeking.png" alt="Rosey" />
			</div>
			<div class="signup-text">
				<h3 class="signup-title">Get Free Wallpapers <img src="/sakura-flower.png" alt="" class="signup-flower" /></h3>
				<p class="signup-sub">Cute kawaii backgrounds for your phone, tablet, and desktop &mdash; totally free!</p>
			</div>
			<a href="/wallpapers" class="signup-btn signup-cta"><img src="/paw-icon.svg" alt="" width="14" height="14" style="vertical-align:-2px;margin-right:5px;filter:brightness(0) invert(1);" />Click Here</a>
		</div>
	</section>

	<!-- Meet the PuchiPaws -->
	<section class="meet">
		<h2 class="section-title"><img src="/sakura-flower.png" alt="" class="title-flower" /> Meet the PuchiPaws <img src="/sakura-flower.png" alt="" class="title-flower" /></h2>
		<div class="meet-row">
			<a href="/puchipaws#suzu" class="meet-card-wrap">
				<div class="meet-card meet-card-blue">
					<div class="meet-char-col">
						<img src="/suzu-single.png" alt="Suzu" class="meet-char" />
					</div>
					<div class="meet-text-col">
						<h3><span class="meet-icon">&#9650;</span> suzu <span class="meet-icon">&#9650;</span></h3>
						<p class="meet-blurb">Playful, sweet,<br/>and a little mischievous.</p>
						<span class="meet-btn meet-btn-blue">View Profile <img src="/paw-icon.svg" alt="" class="meet-btn-icon paw-blue" /></span>
					</div>
				</div>
			</a>
			<a href="/puchipaws#saki" class="meet-card-wrap">
				<div class="meet-card meet-card-pink">
					<div class="meet-char-col">
						<img src="/saki-single.png" alt="Saki" class="meet-char" />
					</div>
					<div class="meet-text-col">
						<h3><span class="meet-icon">&#10047;</span> saki <span class="meet-icon">&#10047;</span></h3>
						<p class="meet-blurb">Creative, kind,<br/>and smart.</p>
						<span class="meet-btn meet-btn-pink">View Profile <img src="/paw-icon.svg" alt="" class="meet-btn-icon paw-pink" /></span>
					</div>
				</div>
			</a>
			<a href="/puchipaws#chizuro" class="meet-card-wrap">
				<div class="meet-card meet-card-purple">
					<div class="meet-char-col">
						<img src="/chizuro-single.png" alt="Chizuro" class="meet-char" />
					</div>
					<div class="meet-text-col">
						<h3><span class="meet-icon">&#9829;</span> chizuro <span class="meet-icon">&#9829;</span></h3>
						<p class="meet-blurb">Calm, quiet,<br/>and possessive.</p>
						<span class="meet-btn meet-btn-purple">View Profile <img src="/paw-icon.svg" alt="" class="meet-btn-icon paw-purple" /></span>
					</div>
				</div>
			</a>
		</div>
	</section>

	<!-- Shop Preview (hidden until store is ready)
	<section class="products" id="products">
		<div class="products-header">
			<h2 class="section-title">Cute things<br/>for happy days</h2>
			<a href="/shop" class="btn btn-sakura btn-sm">Visit the Shop</a>
		</div>
		<div class="products-scroll">
			{products.map((product) => (
				<a href={`/product/${product.slug}`} class="prod-card">
					<div class="prod-img">
						<img src={product.image} alt={product.name} />
					</div>
					<div class="prod-info">
						<span class="prod-name">{product.name}</span>
						<span class="prod-price">{product.price}</span>
					</div>
				</a>
			))}
		</div>
	</section>
	-->

	<!-- Latest from the Channel -->
	<section class="latest">
		<div class="latest-inner">
			<div class="latest-left">
				<img src="/yt-play-pink.png" alt="YouTube" class="latest-yt-icon" />
				<h2 class="latest-title">Latest from<br/>the channel</h2>
				<a href="https://www.youtube.com/@JapanezyArts" target="_blank" rel="noopener" class="btn btn-sakura latest-yt-btn"><img src="/yt-play-pink.png" alt="" width="16" height="16" style="margin-right:6px;filter:brightness(0) invert(1);" />Watch on YouTube</a>
			</div>
			<div class="latest-videos" id="latest-videos">
				<!-- Fallback static content, replaced by JS -->
				<a href="https://www.youtube.com/watch?v=3hJ4ZVumxEk" target="_blank" rel="noopener" class="latest-vid-card">
					<div class="latest-thumb">
						<img src="https://img.youtube.com/vi/3hJ4ZVumxEk/mqdefault.jpg" alt="Capybara Drawing Time-Lapse" />
					</div>
					<h4>Capybara Drawing Time-Lapse</h4>
					<p>A speedy kawaii capybara sketch!</p>
				</a>
				<a href="https://www.youtube.com/watch?v=FdisBeWRiVo" target="_blank" rel="noopener" class="latest-vid-card">
					<div class="latest-thumb">
						<img src="https://img.youtube.com/vi/FdisBeWRiVo/mqdefault.jpg" alt="DIY Soot Sprite Trinket" />
					</div>
					<h4>DIY Soot Sprite Trinket</h4>
					<p>Studio Ghibli kawaii DIY!</p>
				</a>
				<a href="https://www.youtube.com/watch?v=N4Det5Jqutg" target="_blank" rel="noopener" class="latest-vid-card">
					<div class="latest-thumb">
						<img src="https://img.youtube.com/vi/N4Det5Jqutg/mqdefault.jpg" alt="Drawing Challenge: Roblox Hamster" />
					</div>
					<h4>Drawing Challenge: Roblox Hamster</h4>
					<p>Procreate kawaii art challenge!</p>
				</a>
			</div>

			<script>
				(async function loadLatestVideos() {
					try {
						const CHANNEL_ID = 'UC9__kLGuwRYOk9a6IK-ddNw';
						const feedUrl = `https://www.youtube.com/feeds/videos.xml?channel_id=${CHANNEL_ID}`;
						const res = await fetch(`https://api.allorigins.win/raw?url=${encodeURIComponent(feedUrl)}`);
						if (!res.ok) return;
						const xml = await res.text();
						const parser = new DOMParser();
						const doc = parser.parseFromString(xml, 'text/xml');
						const entries = doc.querySelectorAll('entry');

						const videos = [];
						for (const entry of entries) {
							const link = entry.querySelector('link[rel="alternate"]')?.getAttribute('href') || '';
							if (link.includes('/shorts/')) continue;
							const title = entry.querySelector('title').textContent;
							const videoId = entry.querySelector('id').textContent.split(':').pop();
							videos.push({ title, videoId });
							if (videos.length === 3) break;
						}
						if (videos.length < 3) return;

						const container = document.getElementById('latest-videos');
						container.innerHTML = videos.map(v => `
							<a href="https://www.youtube.com/watch?v=${v.videoId}" target="_blank" rel="noopener" class="latest-vid-card">
								<div class="latest-thumb">
									<img src="https://img.youtube.com/vi/${v.videoId}/mqdefault.jpg" alt="${v.title}" />
								</div>
								<h4>${v.title}</h4>
							</a>`).join('');
					} catch (e) {
						// fallback to static content
					}
				})();
			</script>
		</div>
	</section>

	<!-- Share Your Creations -->
	<section class="share">
		<div class="share-inner">
			<div class="share-left">
				<h2>Share your<br/>cute creations</h2>
				<p>Colored a page? Drew one of the PuchiPaws? Tag us for a chance to be featured!</p>
				<div class="share-btns">
					<a href="/printable" class="btn btn-sakura">Get the Printable</a>
					<a href="/fan-art" class="btn btn-cocoa">Submit Your Art</a>
				</div>
			</div>
			<div class="share-right">
				<img src="/puchipaws-clear.png" alt="PuchiPaws" />
			</div>
		</div>
	</section>

	<!-- Final CTA Banner -->
	<section class="bottom-banner">
		<div class="banner-inner">
			<h2>Ready to enter the cute little world?</h2>
			<p>Let's create something kawaii together</p>
			<div class="banner-btns">
				<a href="/puchipaws" class="btn btn-white">Meet the PuchiPaws</a>
			</div>
		</div>
		<div class="banner-char-left">
			<img src="/saki-peeking.png" alt="Saki peeking" />
		</div>
		<div class="banner-char-right">
			<img src="/chizuro-peeking.png" alt="Chizuro peeking" />
		</div>
	</section>

	<!-- About Section -->
	<section class="about" id="about">
		<div class="about-inner">
			<h2>About Japanezy Arts</h2>
			<p>Japanezy Arts is a creative channel dedicated to kawaii artwork. We offer a series of handmade paper crafts/artwork and designs.</p>
		</div>
	</section>

	<!-- Shoutout Popup -->
	<div class="shoutout-overlay" id="shoutout-overlay">
		<div class="shoutout-modal">
			<button class="shoutout-close" id="shoutout-close">&times;</button>
			<h2 class="shoutout-title">Yay, you subscribed!</h2>
			<p class="shoutout-text">Would you like a shoutout?</p>
			<div class="shoutout-buttons">
				<a href="/shoutout" class="btn shoutout-yes">Yes!</a>
				<button class="btn shoutout-no" id="shoutout-no">No thanks</button>
			</div>
		</div>
	</div>
</Layout>

<style>
	/* ===== BRAND COLORS =====
	   Blush Pink: #FFD9E3
	   Sakura Pink: #FF9BB7
	   Warm Cream: #FFF3D6
	   Soft Gold: #FFD166
	   Sky Blue: #AFCBFF
	   Lavender: #CDBBFF
	   Cocoa Brown: #6B3E2E
	   Cloud White: #FFFFFF
	*/

	/* ===== HERO ===== */
	.hero {
		position: relative;
		z-index: 0;
		background: url('/header-bg.png') center top / cover no-repeat;
		padding: 6rem 2rem 0;
		padding-bottom: 0;
		overflow: hidden;
		margin-top: -80px;
	}

	.hero-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 2rem;
		position: relative;
		z-index: 1;
	}

	.hero-text {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.hero-text h1 {
		line-height: 1.15;
		margin-bottom: 1.2rem;
	}

	.hero-line1 {
		font-family: 'Baloo 2', cursive;
		font-size: clamp(1.4rem, 3vw, 2rem);
		color: #6B3E2E;
		font-weight: 800;
	}

	.hero-line2 {
		font-family: 'Baloo 2', cursive;
		font-size: clamp(1.8rem, 4.5vw, 3rem);
		color: #E8879B;
		font-weight: 800;
		paint-order: stroke fill;
		-webkit-text-stroke: 4px #C2687D;
		text-shadow:
			0 1px 0 #B85C70,
			0 2px 0 #AE5065,
			0 3px 0 #A4455A,
			0 4px 0 #9A3A4F,
			0 5px 8px rgba(150, 50, 70, 0.3);
	}

	.hero-line3 {
		font-family: 'Baloo 2', cursive;
		font-size: clamp(2.2rem, 5.5vw, 3.75rem);
		color: #E8879B;
		font-weight: 800;
		paint-order: stroke fill;
		-webkit-text-stroke: 4px #C2687D;
		text-shadow:
			0 1px 0 #B85C70,
			0 2px 0 #AE5065,
			0 3px 0 #A4455A,
			0 4px 0 #9A3A4F,
			0 5px 8px rgba(150, 50, 70, 0.3);
	}

	.hero-line4 {
		font-family: 'Baloo 2', cursive;
		font-size: clamp(2.2rem, 5.5vw, 3.75rem);
		color: #F0C87A;
		font-weight: 800;
		paint-order: stroke fill;
		-webkit-text-stroke: 4px #C9A055;
		text-shadow:
			0 1px 0 #B8904A,
			0 2px 0 #A8803F,
			0 3px 0 #987034,
			0 4px 0 #886029,
			0 5px 8px rgba(150, 100, 40, 0.3);
	}

	.hero-sub {
		font-family: 'Nunito', sans-serif;
		font-size: clamp(0.82rem, 1.2vw, 0.95rem);
		color: #6B3E2E;
		line-height: 1.7;
		margin-bottom: 1.5rem;
		max-width: 400px;
		opacity: 0.85;
	}


	.hero-btns {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		justify-content: center;
	}



	.hero-right {
		flex: 0 1 auto;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		position: relative;
	}

	.hero-logo {
		height: clamp(140px, 20vw, 250px);
		width: auto;
		margin-bottom: 0.5rem;
		position: relative;
		z-index: 4;
	}

	.hc-row {
		width: min(620px, 52vw);
		display: flex;
		align-items: flex-end;
		justify-content: center;
		gap: 2%;
		position: relative;
		z-index: 2;
	}

	.hc-rosey {
		width: 28%;
		height: auto;
		object-fit: contain;
		filter: drop-shadow(0 4px 16px rgba(107, 62, 46, 0.14));
		position: relative;
		z-index: 3;
		transform: translateX(1.25rem);
	}

	.hc-group {
		width: 68%;
		height: auto;
		object-fit: contain;
		filter: drop-shadow(0 4px 16px rgba(107, 62, 46, 0.12));
		position: relative;
		z-index: 2;
	}

	/* ===== BUTTONS ===== */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.55rem 1.2rem;
		border-radius: 10px;
		font-weight: 700;
		font-size: clamp(0.75rem, 0.9vw, 0.85rem);
		transition: all 0.2s;
		text-align: center;
		cursor: pointer;
		border: none;
		font-family: 'Baloo 2', cursive;
		text-decoration: none;
		white-space: nowrap;
	}

	.btn-sm {
		padding: 0.5rem 1.25rem;
		font-size: 0.82rem;
	}

	.btn-sakura {
		background: #FF9BB7;
		color: #fff;
		box-shadow: 0 2px 10px rgba(255, 155, 183, 0.3);
	}

	.btn-sakura:hover {
		background: #F0839F;
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(255, 155, 183, 0.4);
	}

	.btn-cocoa {
		background: #6B3E2E;
		color: #fff;
		box-shadow: 0 2px 10px rgba(107, 62, 46, 0.2);
	}

	.btn-cocoa:hover {
		background: #5A3325;
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(107, 62, 46, 0.3);
	}

	.btn-outline-pink {
		background: #fff;
		color: #FF9BB7;
		border: 2px solid #FF9BB7;
		box-shadow: 0 2px 10px rgba(255, 155, 183, 0.15);
	}

	.btn-outline-pink:hover {
		background: #FFF0F4;
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(255, 155, 183, 0.3);
	}

	.btn-white {
		background: #fff;
		color: #6B3E2E;
		box-shadow: 0 2px 10px rgba(107, 62, 46, 0.1);
	}

	.btn-white:hover {
		background: #FFF3D6;
		transform: translateY(-2px);
	}

	/* ===== YOUTUBE COMPANION ===== */
	.yt-companion {
		background: #FBF5F3;
		padding: 0.75rem 2rem 0.5rem;
		position: relative;
		z-index: 1;
		overflow: visible;
	}

	.yt-companion-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.yt-companion-left {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		flex: 0 0 260px;
	}

	.yt-badge-img {
		width: 44px;
		height: auto;
		flex-shrink: 0;
		margin-top: 0.2rem;
	}

	.yt-companion-title {
		font-family: 'Baloo 2', cursive;
		font-size: 1.05rem;
		color: #6B3E2E;
		line-height: 1.3;
		font-weight: 800;
		margin: 0;
	}


	.yt-companion-sub {
		font-family: 'Nunito', sans-serif;
		font-size: 0.78rem;
		color: #6B3E2E;
		opacity: 0.65;
		line-height: 1.5;
		margin: 0.25rem 0 0.4rem;
	}

	.yt-sub-link {
		font-family: 'Nunito', sans-serif;
		font-size: 0.8rem;
		color: #FF9BB7;
		font-weight: 700;
	}

	.yt-sub-link:hover {
		color: #F0839F;
	}

	.yt-comp-card {
		flex: 1;
		background: #FFF8FA;
		border-radius: 16px;
		padding: 0.5rem 0.5rem 0.4rem;
		display: flex;
		flex-direction: column;
