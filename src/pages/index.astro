	/* ===== SHOUTOUT POPUP ===== */
	.shoutout-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		z-index: 200;
		align-items: center;
		justify-content: center;
	}

	.shoutout-overlay.open { display: flex; }

	.shoutout-modal {
		background: #fff;
		border-radius: 28px;
		padding: 2.5rem 2rem;
		text-align: center;
		position: relative;
		box-shadow: 0 8px 32px rgba(107, 62, 46, 0.2);
		max-width: 380px;
		width: 90%;
	}

	.shoutout-close {
		position: absolute;
		top: 0.75rem;
		right: 1rem;
		background: none;
		border: none;
		font-size: 1.5rem;
		color: #999;
		cursor: pointer;
	}
	.shoutout-close:hover { color: #6B3E2E; }

	.shoutout-title {
		font-family: 'Baloo 2', cursive;
		font-size: 1.4rem;
		color: #FF9BB7;
		margin-bottom: 0.5rem;
	}

	.shoutout-text {
		font-family: 'Nunito', sans-serif;
		font-size: 1rem;
		color: #6B3E2E;
		margin-bottom: 1.5rem;
		opacity: 0.7;
	}

	.shoutout-buttons {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
	}

	.shoutout-yes {
		background: #FF9BB7;
		color: #fff;
		padding: 0.65rem 1.75rem;
	}
	.shoutout-yes:hover { background: #F0839F; }

	.shoutout-no {
		background: #FFD9E3;
		color: #6B3E2E;
		padding: 0.65rem 1.75rem;
	}
	.shoutout-no:hover { background: #FFC8D5; }

	/* ===== MOBILE ===== */
