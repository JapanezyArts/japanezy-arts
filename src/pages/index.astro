	.about {
		background: rgba(255, 255, 255, 0.6);
		padding: 3rem 2rem;
		position: relative;
		z-index: 1;
		border-radius: 32px;
		max-width: 1100px;
		margin: 0 auto 2rem;
	}

	.about-inner {
		max-width: 650px;
		margin: 0 auto;
		text-align: center;
	}

	.about-inner h2 {
		font-family: 'Baloo 2', cursive;
		font-size: 1.5rem;
		margin-bottom: 0.75rem;
		color: #6B3E2E;
	}

	.about-inner p {
		font-family: 'Nunito', sans-serif;
		font-size: 0.95rem;
		line-height: 1.8;
		color: #6B3E2E;
		opacity: 0.8;
