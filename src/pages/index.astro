		align-items: flex-end;
		background: #f5f0f3;
		border-radius: 16px;
		padding: 0.5rem 1rem 0.5rem 0;
		width: 100%;
		border: 1px solid rgba(0,0,0,0.05);
		box-shadow: 0 2px 10px rgba(107, 62, 46, 0.06);
		overflow: visible;
	}

	.meet-card-wrap:hover .meet-card {
		box-shadow: 0 4px 16px rgba(107, 62, 46, 0.12);
	}

	.meet-char-col {
		flex-shrink: 0;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		width: 120px;
	}

	.meet-char {
		height: 190px;
		width: auto;
		position: relative;
		z-index: 2;
		margin-top: -50px;
	}

	.meet-text-col {
		flex: 1;
		text-align: center;
		padding: 0.5rem 0;
	}

	.meet-card h3 {
		font-family: 'Baloo 2', cursive;
		font-size: 1.2rem;
		font-weight: 800;
		text-transform: lowercase;
		letter-spacing: 0.5px;
		margin-bottom: 0.15rem;
	}

	.meet-card-blue, .meet-card-pink, .meet-card-purple { background: #fdf8f9; }
	.meet-card-blue h3 { color: #5B8BD4; }
	.meet-card-pink h3 { color: #E8879B; }
	.meet-card-purple h3 { color: #9B7EC8; }

	.meet-icon {
		font-size: 0.7rem;
		vertical-align: middle;
	}

	.meet-card-blue .meet-icon { color: #5B8BD4; }
	.meet-card-pink .meet-icon { color: #E8879B; }
	.meet-card-purple .meet-icon { color: #9B7EC8; }

	.meet-blurb {
		font-family: 'Nunito', sans-serif;
		font-size: 0.75rem;
		color: #6B3E2E;
		opacity: 0.7;
		line-height: 1.5;
		margin-bottom: 0.5rem;
	}

	.meet-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-family: 'Baloo 2', cursive;
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.3rem 0.9rem;
		border-radius: 8px;
		border: 2px solid;
		background: transparent;
	}

	.meet-btn-icon {
		width: 12px;
		height: 12px;
	}
	.paw-blue {
		filter: invert(52%) sepia(60%) saturate(400%) hue-rotate(185deg) brightness(90%) contrast(90%);
	}
	.paw-pink {
		filter: invert(65%) sepia(30%) saturate(600%) hue-rotate(310deg) brightness(95%) contrast(90%);
	}
	.paw-purple {
		filter: invert(55%) sepia(30%) saturate(500%) hue-rotate(230deg) brightness(90%) contrast(90%);
	}

	.meet-btn-blue { color: #5B8BD4; border-color: #5B8BD4; }
	.meet-btn-pink { color: #E8879B; border-color: #E8879B; }
	.meet-btn-purple { color: #9B7EC8; border-color: #9B7EC8; }

	.meet-btn { transition: all 0.2s; }
	.meet-btn-blue:hover { background: #5B8BD4; color: #fff; }
	.meet-btn-pink:hover { background: #E8879B; color: #fff; }
	.meet-btn-purple:hover { background: #9B7EC8; color: #fff; }
	.meet-btn:hover .meet-btn-icon { filter: brightness(0) invert(1) !important; }

	/* ===== PRODUCTS ===== */
	.products {
		padding: 2.5rem 2rem;
		position: relative;
		z-index: 1;
		background: #fff;
		border-radius: 32px 32px 0 0;
	}

	.products-header {
		max-width: 1100px;
		margin: 0 auto 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.products-header .section-title {
		text-align: left;
		margin-bottom: 0;
	}

	.products-scroll {
		display: flex;
		gap: 1rem;
		overflow-x: auto;
		padding: 0.5rem 0 1rem;
		max-width: 1100px;
		margin: 0 auto;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
	}

	.products-scroll::-webkit-scrollbar {
		height: 5px;
	}
	.products-scroll::-webkit-scrollbar-track {
		background: #FFD9E3;
		border-radius: 3px;
	}
	.products-scroll::-webkit-scrollbar-thumb {
		background: #FF9BB7;
		border-radius: 3px;
	}

	.prod-card {
		flex: 0 0 175px;
		background: #FFF8FA;
		border-radius: 20px;
		padding: 0.75rem;
		transition: all 0.25s;
		scroll-snap-align: start;
		border: 1px solid rgba(255, 155, 183, 0.12);
	}

	.prod-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 20px rgba(255, 155, 183, 0.15);
	}

	.prod-img {
		width: 100%;
		aspect-ratio: 1;
		border-radius: 14px;
		overflow: hidden;
		margin-bottom: 0.5rem;
	}

	.prod-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.prod-info {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.prod-name {
		font-family: 'Nunito', sans-serif;
		font-size: 0.8rem;
		color: #6B3E2E;
		font-weight: 700;
		line-height: 1.3;
	}

	.prod-price {
		font-family: 'Baloo 2', cursive;
		font-size: 0.85rem;
		color: #FF9BB7;
		font-weight: 800;
	}

	/* ===== LATEST ===== */
	.latest {
		padding: 1.5rem 2rem;
		position: relative;
		z-index: 1;
		background: #f9f1f1;
	}

	.latest-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.latest-left {
		flex: 0 0 200px;
	}

	.latest-yt-icon {
		width: 44px;
		height: auto;
		margin-bottom: 0.75rem;
	}

	.latest-title {
		font-family: 'Baloo 2', cursive;
		font-size: 1.3rem;
		font-weight: 800;
		color: #6B3E2E;
		line-height: 1.2;
		margin-bottom: 0.3rem;
	}

	.latest-sub {
		font-family: 'Nunito', sans-serif;
		font-size: 0.8rem;
		color: #6B3E2E;
		opacity: 0.6;
		margin-bottom: 1rem;
	}

	.latest-yt-btn {
		font-size: 0.8rem;
		padding: 0.5rem 1rem;
	}

	.latest-videos {
		flex: 1;
		display: flex;
		gap: 1rem;
	}

	.latest-vid-card {
		flex: 1;
		text-decoration: none;
