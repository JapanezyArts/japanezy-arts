	.signup-form {
		display: flex;
		align-items: center;
		gap: 0;
		flex: 0 0 auto;
		background: #fff;
		border-radius: 12px;
		padding: 0.25rem;
		box-shadow: 0 2px 8px rgba(107, 62, 46, 0.06);
		position: relative;
		z-index: 1;
