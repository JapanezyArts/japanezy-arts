---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Japanezy Arts - Home">
	<!-- Hero Section -->
	<section class="hero">
		<img src="/ja-main-logo.png" alt="Japanezy Arts" class="hero-logo" />
		<p>Art, paper crafts, and more with tutorials and ASMR</p>
		<a href="https://www.youtube.com/@JapanezyArts" target="_blank" rel="noopener" class="btn btn-primary">Watch on YouTube</a>
	</section>

	<!-- Characters Section -->
	<section class="characters-section">
		<h2>Meet Puchipaws</h2>
		<img src="/puchipaws.png" alt="Puchipaws characters" class="characters-banner" />
		<a href="/printable" class="btn btn-primary" style="margin-top: 2rem;">Free Printable Sheet</a>
	</section>

	<!-- Videos Section -->
	<section class="videos-section">
		<h2>Latest from Japanezy Arts</h2>
		<h3 class="video-title">Latest Video</h3>

		<div class="video-card">
			<div class="video-wrapper">
				<iframe
					src="https://www.youtube.com/embed/ye-XFUdnoaY"
					title="Latest Video"
					frameborder="0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					allowfullscreen
				></iframe>
			</div>
		</div>

		<a href="https://www.youtube.com/@JapanezyArts" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top: 2rem;">
			Visit the Full Channel
		</a>
	</section>

	<!-- About Section -->
	<section class="about-section" id="about">
		<div class="about-content">
			<h2>About Me</h2>
			<p>
				Japanezy Arts is a creative channel dedicated to kawaii artwork.
				We offer a series of handmade paper crafts/artwork and designs.
			</p>
		</div>
	</section>

	<!-- Subscribe Section -->
	<section class="subscribe-section">
		<h2>Subscribe</h2>
		<button id="subscribe-btn" class="btn subscribe-btn">Subscribe on YouTube</button>
		<p class="subscribe-note">Subscribe for a shoutout!</p>
	</section>

	<!-- Shoutout Popup -->
	<div class="shoutout-overlay" id="shoutout-overlay">
		<div class="shoutout-modal">
			<button class="shoutout-close" id="shoutout-close">&times;</button>
			<h2 class="shoutout-title">Yay, you subscribed!</h2>
			<p class="shoutout-text">Would you like a shoutout?</p>
			<div class="shoutout-buttons">
				<a href="/shoutout" class="btn shoutout-yes">Yes!</a>
				<button class="btn shoutout-no" id="shoutout-no">No thanks</button>
			</div>
		</div>
	</div>
</Layout>

<style>
	/* Hero */
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 4rem 2rem;
		min-height: 60vh;
		position: relative;
		z-index: 1;
	}

	.hero-logo {
		height: 600px;
		width: auto;
		margin-bottom: 1.5rem;
	}

	.hero p {
		font-size: clamp(1rem, 2vw, 1.25rem);
		color: #7a6b7a;
		margin-bottom: 2rem;
	}

	/* Buttons */
	.btn {
		display: inline-block;
		padding: 0.85rem 2rem;
		border-radius: 6px;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.2s;
	}

	.btn-primary {
		background: #d5b3f5;
		color: #fff;
	}

	.btn-primary:hover {
		background: #c9a3eb;
	}

	/* Videos Section */
	.videos-section {
		padding: 4rem 2rem;
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.videos-section h2 {
		font-size: 2.25rem;
		margin-bottom: 0.5rem;
		color: #333;
	}

	.video-title {
		color: #555;
		font-size: 1.25rem;
		margin-bottom: 2rem;
	}

	.video-card {
		background: #fff;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 16px rgba(155, 89, 182, 0.15);
	}

	.video-wrapper {
		position: relative;
		padding-bottom: 56.25%;
		height: 0;
	}

	.video-wrapper iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	/* Characters Section */
	.characters-section {
		padding: 4rem 2rem;
		text-align: center;
		position: relative;
		z-index: 1;
		max-width: 900px;
		margin: 0 auto;
	}

	.characters-section h2 {
		font-size: 2.25rem;
		margin-bottom: 2rem;
		color: #333;
	}

	.characters-banner {
		width: 100%;
		max-width: 800px;
		height: auto;
		border-radius: 12px;
	}

	/* About Section */
	.about-section {
		background: rgba(255, 255, 255, 0.5);
		padding: 5rem 2rem;
		position: relative;
		z-index: 1;
	}

	.about-content {
		max-width: 700px;
		margin: 0 auto;
		text-align: center;
	}

	.about-content h2 {
		font-size: 2.25rem;
		margin-bottom: 1.5rem;
		color: #333;
	}

	.about-content p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: #555;
	}

	/* Subscribe Section */
	.subscribe-section {
		padding: 3rem 2rem;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.subscribe-section h2 {
		font-size: 2.25rem;
		color: #e53935;
		margin-bottom: 1.5rem;
	}

	.subscribe-btn {
		background: #e53935;
		color: #fff;
		font-size: 1.1rem;
		padding: 1rem 2.5rem;
	}

	.subscribe-btn:hover {
		background: #c62828;
	}

	.subscribe-note {
		margin-top: 1rem;
		color: #e53935;
		font-size: 1rem;
		font-weight: 600;
	}

	.subscribe-btn {
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
	}

	/* Shoutout Popup */
	.shoutout-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		z-index: 200;
		align-items: center;
		justify-content: center;
	}

	.shoutout-overlay.open {
		display: flex;
	}

	.shoutout-modal {
		background: #fff;
		border-radius: 16px;
		padding: 2.5rem 2rem;
		text-align: center;
		position: relative;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
		max-width: 400px;
		width: 90%;
	}

	.shoutout-close {
		position: absolute;
		top: 0.75rem;
		right: 1rem;
		background: none;
		border: none;
		font-size: 1.5rem;
		color: #999;
		cursor: pointer;
	}

	.shoutout-close:hover {
		color: #333;
	}

	.shoutout-title {
		font-size: 1.5rem;
		color: #e53935;
		margin-bottom: 0.5rem;
	}

	.shoutout-text {
		font-size: 1.1rem;
		color: #555;
		margin-bottom: 1.5rem;
	}

	.shoutout-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.shoutout-yes {
		background: #e53935;
		color: #fff;
		padding: 0.75rem 2rem;
	}

	.shoutout-yes:hover {
		background: #c62828;
	}

	.shoutout-no {
		background: #ddd;
		color: #555;
		padding: 0.75rem 2rem;
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
	}

	.shoutout-no:hover {
		background: #ccc;
	}
</style>

<script>
	const subscribeBtn = document.getElementById('subscribe-btn');
	const overlay = document.getElementById('shoutout-overlay');
	const closeBtn = document.getElementById('shoutout-close');
	const noBtn = document.getElementById('shoutout-no');

	subscribeBtn?.addEventListener('click', () => {
		window.open('https://www.youtube.com/@JapanezyArts?sub_confirmation=1', '_blank');
		overlay?.classList.add('open');
	});

	closeBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
	noBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
	overlay?.addEventListener('click', (e) => {
		if (e.target === overlay) overlay.classList.remove('open');
	});
</script>

<style>
	@media (max-width: 768px) {
		.hero {
			padding: 2.5rem 1.25rem;
			min-height: 45vh;
		}

		.hero-logo {
			height: 300px;
		}

		.characters-section {
			padding: 2.5rem 1rem;
		}

		.characters-section h2 {
			font-size: 1.75rem;
		}

		.videos-section,
		.about-section {
			padding: 2.5rem 1rem;
		}

		.videos-section h2,
		.about-content h2 {
			font-size: 1.75rem;
		}

		.about-content p {
			font-size: 1rem;
		}
	}
</style>
