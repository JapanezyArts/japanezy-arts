<script>
	const overlay = document.getElementById('shoutout-overlay');
	const closeBtn = document.getElementById('shoutout-close');
	const noBtn = document.getElementById('shoutout-no');

	closeBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
	noBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
	overlay?.addEventListener('click', (e) => {
		if (e.target === overlay) overlay.classList.remove('open');
	});

</script>
