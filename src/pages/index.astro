	.banner-inner {
		text-align: center;
		position: relative;
		z-index: 2;
		flex: 1;
		max-width: 520px;
	}

	.banner-inner h2 {
		font-family: 'Baloo 2', cursive;
		font-size: clamp(1.5rem, 3vw, 2rem);
		color: #fff;
		margin-bottom: 0.5rem;
		line-height: 1.2;
	}

	.banner-inner p {
		font-family: 'Nunito', sans-serif;
		color: rgba(255, 255, 255, 0.9);
		margin-bottom: 1.25rem;
		font-size: 0.95rem;
	}

	.banner-btns {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
