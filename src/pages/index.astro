		font-weight: 800;
		color: #6B3E2E;
		margin: 0 0 0.1rem;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		white-space: nowrap;
	}

	.signup-flower {
		width: 24px;
		height: 24px;
		object-fit: contain;
	}

	.signup-sub {
		font-family: 'Nunito', sans-serif;
		font-size: 0.68rem;
		color: #6B3E2E;
		opacity: 0.7;
		line-height: 1.4;
		margin: 0;
