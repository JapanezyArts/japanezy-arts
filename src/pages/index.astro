		font-family: 'Nunito', sans-serif;
		font-size: 0.72rem;
		color: #6B3E2E;
		opacity: 0.6;
	}

	/* ===== SHARE ===== */
	.share {
		padding: 2.5rem 2rem;
		position: relative;
		z-index: 1;
		background: #fff;
		border-radius: 32px;
		max-width: 1100px;
		margin: 0 auto;
