	/* ===== SECTION TITLES ===== */
	.section-title {
		font-family: 'Baloo 2', cursive;
		font-size: 1.5rem;
		color: #6B3E2E;
		text-align: center;
		margin-bottom: 1.5rem;
		font-weight: 800;
	}

	/* ===== MEET THE PUCHIPAWS ===== */
	.title-flower {
		width: 18px;
		height: 18px;
		object-fit: contain;
		vertical-align: middle;
	}

	.meet {
		padding: 1rem 2rem 2rem;
		position: relative;
		z-index: 1;
	}

	.meet-row {
		display: flex;
		gap: 1.5rem;
		justify-content: center;
		align-items: flex-start;
		max-width: 1000px;
		margin: 0 auto;
	}

	.meet-card-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		position: relative;
		flex: 1;
		max-width: 360px;
		text-decoration: none;
		transition: all 0.25s;
	}

	.meet-card-wrap:hover {
		transform: translateY(-4px);
	}

	.meet-card {
