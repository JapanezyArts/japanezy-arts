	.share-btns {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.share-right {
		flex: 0 0 auto;
	}

	.share-right img {
		height: clamp(160px, 22vw, 280px);
		width: auto;
	}

	/* ===== BOTTOM BANNER ===== */
	.bottom-banner {
		background: linear-gradient(135deg, #FFD9E3 0%, #FF9BB7 50%, #FF85A8 100%);
		padding: 3rem 2rem;
		position: relative;
		z-index: 1;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 32px;
		max-width: 1100px;
