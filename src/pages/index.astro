		left: 2%;
		top: -18px;
		opacity: 1;
		transform: rotate(-15deg);
	}

	.deco-heart2 {
		width: 20px;
		left: 10%;
		top: 4px;
		opacity: 0.85;
		transform: rotate(10deg);
	}

	.deco-heart3 {
		width: 22px;
		left: 5%;
		bottom: -10px;
		opacity: 0.75;
		transform: rotate(-5deg);
	}

	.deco-heart4 {
		width: 16px;
		right: 20%;
		top: -12px;
		opacity: 0.8;
		transform: rotate(20deg);
	}

	.deco-heart5 {
		width: 18px;
		right: 4%;
		bottom: -8px;
		opacity: 0.7;
		transform: rotate(-10deg);
	}

	.deco-sparkle1 {
		width: 35px;
		right: 12%;
		top: -18px;
		opacity: 1;
	}

	.deco-sparkle2 {
		width: 28px;
		left: 30%;
		top: -14px;
		opacity: 0.85;
	}

	.deco-sparkle3 {
		width: 30px;
		right: 2%;
		top: 50%;
		transform: translateY(-50%);
		opacity: 0.8;
	}

	.deco-sparkle4 {
		width: 24px;
		left: 52%;
		bottom: -12px;
		opacity: 0.7;
	}

	.deco-flower1 {
		width: 20px;
		right: 7%;
		bottom: 4px;
		opacity: 0.85;
	}

	.deco-flower2 {
		width: 16px;
		left: 40%;
		bottom: 2px;
		opacity: 0.7;
	}

	.signup-char {
