---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rosey - Japanezy Arts">
	<section class="rosey-page">
		<div class="rosey-inner">
			<div class="rosey-img-col">
				<img src="/rosey-hero.png" alt="Rosey holding a paintbrush" class="rosey-img" />
			</div>
			<div class="rosey-about-col">
				<span class="rosey-eyebrow">Meet the Main Character</span>
				<h1 class="rosey-title">About Rosey</h1>
				<p class="rosey-bio">
					Rosey is my real dog in real life. She is my best friend, and she watches all the videos with me and edits them with me.
				</p>
				<p class="rosey-bio">
					She is very playful, and she's always dirty from playing outside. She loves me so much &mdash; I'm her mama.
					<img src="/paw-icon.svg" alt="" class="rosey-paw" />
				</p>
			</div>
		</div>

		<div class="rosey-photo-section">
			<h2 class="rosey-photo-heading">The Real Rosey</h2>
			<div class="rosey-photos">
				<figure class="rosey-polaroid">
					<img src="/roseyirl.jpg" alt="A photo of the real Rosey, a Yorkie, in her red gingham shirt" />
					<figcaption>My best friend &amp; art buddy <img src="/paw-icon.svg" alt="" class="rosey-paw" /></figcaption>
				</figure>
				<figure class="rosey-polaroid rosey-polaroid-alt">
					<img src="/roseysleeping.jpg" alt="Rosey sleeping in her fluffy pink and white bed" />
					<figcaption>Just another day of sleeping <img src="/paw-icon.svg" alt="" class="rosey-paw" /></figcaption>
				</figure>
			</div>
		</div>
	</section>
</Layout>

<style>
	.rosey-page {
		max-width: 1100px;
		margin: 0 auto;
		padding: 4rem 2rem 5rem;
	}

	.rosey-inner {
		display: flex;
		align-items: center;
		gap: 3.5rem;
	}

	.rosey-img-col {
		flex: 0 0 auto;
		width: min(420px, 42%);
		display: flex;
		justify-content: center;
	}

	.rosey-img {
		width: 100%;
		height: auto;
		filter: drop-shadow(0 10px 26px rgba(107, 62, 46, 0.18));
	}

	.rosey-about-col {
		flex: 1;
		min-width: 0;
		background: rgba(255, 255, 255, 0.7);
		border-radius: 24px;
		padding: 2.75rem 2.5rem;
		box-shadow: 0 6px 26px rgba(210, 130, 120, 0.12);
	}

	.rosey-eyebrow {
		display: inline-block;
		font-weight: 700;
		font-size: 0.9rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #e07a94;
		background: #ffe6ec;
		padding: 0.35rem 0.9rem;
		border-radius: 20px;
		margin-bottom: 1rem;
	}

	.rosey-title {
		font-size: clamp(2rem, 4vw, 3rem);
		color: #d96c85;
		margin-bottom: 1.25rem;
		line-height: 1.1;
	}

	.rosey-bio {
		font-size: 1.15rem;
		line-height: 1.9;
		color: #5f5560;
		margin-bottom: 1.1rem;
	}

	.rosey-bio:last-child {
		margin-bottom: 0;
	}

	.rosey-paw {
		width: 20px;
		height: 20px;
		vertical-align: -3px;
		margin-left: 2px;
	}

	.rosey-photo-section {
		margin-top: 4rem;
		text-align: center;
	}

	.rosey-photo-heading {
		font-size: clamp(1.6rem, 3vw, 2.25rem);
		color: #d96c85;
		margin-bottom: 1.75rem;
	}

	.rosey-photos {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: flex-start;
		gap: 2.5rem;
	}

	.rosey-polaroid {
		background: #FF9BB7;
		padding: 0.85rem 0.85rem 1.25rem;
		border-radius: 8px;
		box-shadow: 0 10px 30px rgba(107, 62, 46, 0.18);
		transform: rotate(-2.5deg);
		flex: 0 1 320px;
		max-width: 320px;
	}

	.rosey-polaroid-alt {
		transform: rotate(2.5deg);
	}

	.rosey-polaroid img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 4px;
	}

	.rosey-polaroid figcaption {
		margin-top: 0.85rem;
		font-size: 1.05rem;
		color: #fff;
		font-weight: 600;
	}

	.rosey-polaroid .rosey-paw {
		width: 18px;
		height: 18px;
		vertical-align: -3px;
		filter: brightness(0) invert(1);
	}

	@media (max-width: 768px) {
		.rosey-page {
			padding: 2.5rem 1.25rem 4rem;
		}

		.rosey-photo-section {
			margin-top: 2.5rem;
		}

		.rosey-inner {
			flex-direction: column;
			gap: 2rem;
		}

		.rosey-img-col {
			width: min(300px, 75%);
		}

		.rosey-about-col {
			text-align: center;
			padding: 2rem 1.5rem;
		}

		.rosey-bio { font-size: 1.05rem; line-height: 1.8; }

		.rosey-photos { gap: 1.75rem; }

		.rosey-polaroid {
			flex: 0 1 260px;
			max-width: 78%;
			transform: rotate(-1.5deg);
		}

		.rosey-polaroid-alt { transform: rotate(1.5deg); }
	}

	@media (max-width: 480px) {
		.rosey-page { padding: 2rem 1rem 3.5rem; }

		.rosey-about-col { padding: 1.75rem 1.25rem; }

		.rosey-polaroid {
			max-width: 88%;
			transform: rotate(-1.5deg);
		}
	}
</style>
