---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Send Fan Art - Japanezy Arts">
	<section class="fanart-section">
		<a href="/printable" class="close-btn" aria-label="Back to coloring page">&times;</a>
		<h2>Send Your Fan Art</h2>
		<p class="fanart-subtitle">Take a picture of your drawing and send it to Japanezy!</p>

		<!-- Camera Preview -->
		<div class="camera-area" id="camera-area">
			<video id="camera-preview" autoplay playsinline class="camera-preview"></video>
			<img id="photo-preview" class="photo-preview" alt="Your photo" />
		</div>

		<div class="camera-controls">
			<button class="btn camera-btn" id="start-camera">Open Camera</button>
			<button class="btn capture-btn" id="capture-btn" style="display:none;">Take Photo</button>
			<button class="btn retake-btn" id="retake-btn" style="display:none;">Retake</button>
		</div>

		<p class="or-text">— or upload a photo —</p>

		<form id="fanart-form" class="fanart-form">
			<input type="hidden" name="_subject" value="New Fan Art from Japanezy Arts!" />
			<input type="hidden" name="_captcha" value="false" />

			<label class="upload-label" id="upload-label">
				<span class="upload-text" id="upload-text">Tap to upload a photo</span>
				<input type="file" name="attachment" accept="image/*" class="upload-input" id="upload-input" />
			</label>

			<input type="text" name="from" placeholder="From (your name)" class="name-input" />
			<textarea name="letter" placeholder="Write a letter to Japanezy (optional)" class="letter-input" rows="4"></textarea>

			<button type="submit" class="btn send-btn" id="send-btn">Send Fan Art</button>
		</form>
	</section>
</Layout>

<style>
	.close-btn {
		position: absolute;
		top: 0.75rem;
		left: 0.75rem;
		width: 40px;
		height: 40px;
		background: #fff;
		border: 2px solid #ddd;
		border-radius: 50%;
		font-size: 1.5rem;
		line-height: 36px;
		text-align: center;
		color: #666;
		text-decoration: none;
		z-index: 10;
		transition: all 0.2s;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}

	.close-btn:hover {
		background: #f8bbd0;
		color: #fff;
		border-color: #f8bbd0;
	}

	.fanart-section {
		padding: 4rem 2rem;
		text-align: center;
		position: relative;
		z-index: 1;
		max-width: 550px;
		margin: 0 auto;
	}

	.fanart-section h2 {
		font-size: 2.25rem;
		color: #9b59b6;
		margin-bottom: 0.5rem;
	}

	.fanart-subtitle {
		color: #666;
		margin-bottom: 2rem;
		font-size: 1.1rem;
	}

	.camera-area {
		width: 100%;
		max-width: 400px;
		margin: 0 auto 1rem;
		border-radius: 12px;
		overflow: hidden;
		background: #000;
		display: none;
	}

	.camera-area.active {
		display: block;
	}

	.camera-preview {
		width: 100%;
		display: block;
		border-radius: 12px;
	}

	.photo-preview {
		width: 100%;
		display: none;
		border-radius: 12px;
	}

	.camera-controls {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		margin-bottom: 1.5rem;
	}

	.camera-btn {
		background: #9b59b6;
		color: #fff;
		padding: 0.75rem 1.5rem;
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.95rem;
		border-radius: 6px;
		transition: background 0.2s;
	}

	.camera-btn:hover {
		background: #8e44ad;
	}

	.capture-btn {
		background: #e53935;
		color: #fff;
		padding: 0.75rem 1.5rem;
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.95rem;
		border-radius: 6px;
		transition: background 0.2s;
	}

	.capture-btn:hover {
		background: #c62828;
	}

	.retake-btn {
		background: #f8bbd0;
		color: #fff;
		padding: 0.75rem 1.5rem;
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.95rem;
		border-radius: 6px;
		transition: background 0.2s;
	}

	.retake-btn:hover {
		background: #f4a9c1;
	}

	.or-text {
		color: #999;
		font-size: 0.9rem;
		margin-bottom: 1rem;
	}

	.fanart-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.upload-label {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		max-width: 400px;
		min-height: 120px;
		border: 3px dashed #d5b3f5;
		border-radius: 12px;
		cursor: pointer;
		transition: all 0.2s;
		background: #faf5ff;
	}

	.upload-label:hover {
		border-color: #9b59b6;
		background: #f3e8ff;
	}

	.upload-label.has-file {
		border-color: #4caf50;
		background: #f0fff0;
	}

	.upload-text {
		color: #9b59b6;
		font-weight: 600;
		font-size: 1rem;
		padding: 1rem;
	}

	.upload-input {
		display: none;
	}

	.name-input {
		width: 100%;
		max-width: 400px;
		padding: 0.85rem 1rem;
		border: 2px solid #ddd;
		border-radius: 8px;
		font-size: 1rem;
		font-family: 'Inter', sans-serif;
		outline: none;
		transition: border-color 0.2s;
	}

	.name-input:focus {
		border-color: #9b59b6;
	}

	.letter-input {
		width: 100%;
		max-width: 400px;
		padding: 0.85rem 1rem;
		border: 2px solid #ddd;
		border-radius: 8px;
		font-size: 1rem;
		font-family: 'Inter', sans-serif;
		outline: none;
		transition: border-color 0.2s;
		resize: vertical;
	}

	.letter-input:focus {
		border-color: #9b59b6;
	}

	.send-btn {
		background: #d5b3f5;
		color: #fff;
		padding: 0.85rem 2.5rem;
		border: none;
		cursor: pointer;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		font-weight: 600;
		border-radius: 6px;
		transition: background 0.2s;
	}

	.send-btn:hover {
		background: #c9a3eb;
	}

	.send-btn:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	@media (max-width: 768px) {
		.fanart-section {
			padding: 2.5rem 1rem;
		}

		.fanart-section h2 {
			font-size: 1.75rem;
		}
	}
</style>

<script>
	const startBtn = document.getElementById('start-camera') as HTMLButtonElement;
	const captureBtn = document.getElementById('capture-btn') as HTMLButtonElement;
	const retakeBtn = document.getElementById('retake-btn') as HTMLButtonElement;
	const cameraArea = document.getElementById('camera-area');
	const video = document.getElementById('camera-preview') as HTMLVideoElement;
	const photoPreview = document.getElementById('photo-preview') as HTMLImageElement;
	const uploadInput = document.getElementById('upload-input') as HTMLInputElement;
	const uploadLabel = document.getElementById('upload-label');
	const uploadText = document.getElementById('upload-text');

	let stream: MediaStream | null = null;
	let capturedFile: File | null = null;

	// Open camera
	startBtn?.addEventListener('click', async () => {
		try {
			stream = await navigator.mediaDevices.getUserMedia({
				video: { facingMode: 'environment' }
			});
			video.srcObject = stream;
			video.style.display = 'block';
			photoPreview.style.display = 'none';
			cameraArea?.classList.add('active');
			startBtn.style.display = 'none';
			captureBtn.style.display = 'inline-block';
		} catch (err) {
			alert('Could not access camera. Please upload a photo instead.');
		}
	});

	// Take photo - convert canvas to a real File
	captureBtn?.addEventListener('click', () => {
		const canvas = document.createElement('canvas');
		canvas.width = video.videoWidth;
		canvas.height = video.videoHeight;
		const ctx = canvas.getContext('2d');
		ctx?.drawImage(video, 0, 0);

		// Show preview
		const dataUrl = canvas.toDataURL('image/jpeg', 0.9);
		photoPreview.src = dataUrl;
		photoPreview.style.display = 'block';
		video.style.display = 'none';

		// Convert to a real File object
		canvas.toBlob((blob) => {
			if (blob) {
				capturedFile = new File([blob], 'fan-art-photo.jpg', { type: 'image/jpeg' });
			}
		}, 'image/jpeg', 0.9);

		// Stop camera
		stream?.getTracks().forEach(t => t.stop());

		captureBtn.style.display = 'none';
		retakeBtn.style.display = 'inline-block';
	});

	// Retake
	retakeBtn?.addEventListener('click', async () => {
		try {
			stream = await navigator.mediaDevices.getUserMedia({
				video: { facingMode: 'environment' }
			});
			video.srcObject = stream;
			video.style.display = 'block';
			photoPreview.style.display = 'none';
			capturedFile = null;
			retakeBtn.style.display = 'none';
			captureBtn.style.display = 'inline-block';
		} catch (err) {
			alert('Could not access camera.');
		}
	});

	// File upload
	uploadInput?.addEventListener('change', () => {
		if (uploadInput.files && uploadInput.files.length > 0) {
			uploadLabel?.classList.add('has-file');
			if (uploadText) uploadText.textContent = uploadInput.files[0].name;
			// Clear any camera capture
			capturedFile = null;
		}
	});

	// Submit form
	const form = document.getElementById('fanart-form') as HTMLFormElement;
	const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		// Must have either a camera photo or uploaded file
		if (!capturedFile && (!uploadInput.files || uploadInput.files.length === 0)) {
			alert('Please take a photo or upload an image first!');
			return;
		}

		sendBtn.disabled = true;
		sendBtn.textContent = 'Sending...';

		const formData = new FormData(form);

		// If photo was taken with camera, add it as the attachment
		if (capturedFile) {
			formData.set('attachment', capturedFile);
		}

		try {
			await fetch('https://formsubmit.co/ajax/scarlettsburt@icloud.com', {
				method: 'POST',
				body: formData,
			});
		} catch (err) {
			// Still redirect
		}
		window.location.href = '/drawing-thanks';
	});
</script>
