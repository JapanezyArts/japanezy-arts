---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Shop - Japanezy Arts">
	<section class="shop-hero">
		<h1>Shop</h1>
		<p>Original Japanese-inspired artwork available for purchase</p>
	</section>

	<section class="shop-section">
		<p class="coming-soon">Artwork listings coming soon. Stay tuned!</p>
		<a href="https://www.youtube.com/@JapanezyArts" target="_blank" rel="noopener" class="btn">
			Follow on YouTube for Updates
		</a>
	</section>
</Layout>

<style>
	.shop-hero {
		background: linear-gradient(135deg, #3D2B1F 0%, #5C3D2E 50%, #3D2B1F 100%);
		color: #FFF5EE;
		text-align: center;
		padding: 5rem 2rem;
	}

	.shop-hero h1 {
		font-size: 3rem;
		margin-bottom: 0.75rem;
	}

	.shop-hero p {
		color: #F2A6B5;
		font-size: 1.1rem;
	}

	.shop-section {
		max-width: 800px;
		margin: 0 auto;
		padding: 5rem 2rem;
		text-align: center;
	}

	.coming-soon {
		font-size: 1.25rem;
		color: #666;
		margin-bottom: 2rem;
	}

	.btn {
		display: inline-block;
		padding: 0.85rem 2rem;
		background: #D4816B;
		color: #fff;
		border-radius: 6px;
		font-weight: 600;
		font-size: 0.95rem;
		transition: background 0.2s;
	}

	.btn:hover {
		background: #C9704F;
	}

	@media (max-width: 768px) {
		.shop-hero {
			padding: 3rem 1.25rem;
		}

		.shop-hero h1 {
			font-size: 2.25rem;
		}

		.shop-hero p {
			font-size: 1rem;
		}

		.shop-section {
			padding: 3rem 1.25rem;
		}

		.coming-soon {
			font-size: 1.1rem;
		}

		.btn {
			display: block;
			width: 100%;
			box-sizing: border-box;
			text-align: center;
			padding: 0.9rem 1rem;
		}
	}

	@media (max-width: 480px) {
		.shop-hero h1 {
			font-size: 1.9rem;
		}
	}
</style>
