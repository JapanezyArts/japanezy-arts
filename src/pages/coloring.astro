---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Coloring Pages - Japanezy Arts">
	<section class="coloring-section">
		<a href="/" class="close-btn" aria-label="Back to home">&times;</a>
		<h2>Coloring Pages</h2>
		<p class="coloring-subtitle">Print them out, trace and color in your favorite PuchiPaws characters!</p>
		<p class="coloring-instructions">Tap a coloring page to preview, then print.</p>

		<div class="orientation-tabs">
			<button class="orientation-tab active" data-orient="horizontal">Horizontal</button>
			<button class="orientation-tab" data-orient="vertical">Vertical</button>
		</div>

		<div class="coloring-grid" id="horizontal-grid">
			<div class="coloring-card" data-src="/puchipaws-coloring.png">
				<img src="/puchipaws-coloring.png" alt="PuchiPaws Coloring Page" />
			</div>
			<div class="coloring-card" data-src="/puchipaws-coloring-1.png">
				<img src="/puchipaws-coloring-1.png" alt="PuchiPaws Coloring Page 1" />
			</div>
		</div>

		<div class="coloring-grid hidden" id="vertical-grid">
			<div class="coloring-card" data-src="/puchipaws-coloring-2.png">
				<img src="/puchipaws-coloring-2.png" alt="PuchiPaws Coloring Page 2" />
			</div>
			<div class="coloring-card" data-src="/puchipaws-coloring-3.png">
				<img src="/puchipaws-coloring-3.png" alt="PuchiPaws Coloring Page 3" />
			</div>
			<div class="coloring-card" data-src="/puchipaws-coloring-4.png">
				<img src="/puchipaws-coloring-4.png" alt="PuchiPaws Coloring Page 4" />
			</div>
			<div class="coloring-card" data-src="/puchipaws-coloring-5.png">
				<img src="/puchipaws-coloring-5.png" alt="PuchiPaws Coloring Page 5" />
			</div>
			<div class="coloring-card" data-src="/puchipaws-coloring-6.png">
				<img src="/puchipaws-coloring-6.png" alt="PuchiPaws Coloring Page 6" />
			</div>
		</div>

		<!-- Preview Modal -->
		<div class="cp-overlay" id="cp-overlay">
			<div class="cp-modal">
				<button class="cp-close" id="cp-close">&times;</button>
				<img src="" alt="Coloring Page Preview" id="cp-preview" class="cp-preview" />
				<div class="cp-actions">
					<button class="cp-btn cp-btn-print" id="cp-print">Print</button>
				</div>
			</div>
		</div>

		<div class="notice">
			<p class="notice-title">NOTICE</p>
			<p>These coloring pages are for personal use only.</p>
			<p>Do not post on social media without tagging Japanezy Arts.</p>
		</div>
	</section>
</Layout>

<script>
	document.querySelectorAll('.orientation-tab').forEach(tab => {
		tab.addEventListener('click', () => {
			document.querySelectorAll('.orientation-tab').forEach(t => t.classList.remove('active'));
			tab.classList.add('active');
			const orient = tab.dataset.orient;
			document.getElementById('horizontal-grid')?.classList.toggle('hidden', orient !== 'horizontal');
			document.getElementById('vertical-grid')?.classList.toggle('hidden', orient !== 'vertical');
		});
	});

	document.querySelectorAll('.coloring-card').forEach(card => {
		card.addEventListener('click', () => {
			const imgSrc = card.dataset.src;
			const overlay = document.getElementById('cp-overlay');
			const preview = document.getElementById('cp-preview');
			preview.src = imgSrc;
			overlay.classList.add('open');
		});
	});

	document.getElementById('cp-close')?.addEventListener('click', () => {
		document.getElementById('cp-overlay')?.classList.remove('open');
	});

	document.getElementById('cp-overlay')?.addEventListener('click', (e) => {
		if (e.target === e.currentTarget) {
			e.currentTarget.classList.remove('open');
		}
	});

	document.getElementById('cp-print')?.addEventListener('click', () => {
		const imgSrc = document.getElementById('cp-preview').src;
		const win = window.open('', '_blank');
		win.document.write(`<html><head><title>Print Coloring Page</title><style>body{margin:0;display:flex;justify-content:center;align-items:center;min-height:100vh}img{max-width:100%;max-height:100vh}@media print{body{margin:0}img{max-width:100%;max-height:100%}}</style></head><body><img src="${imgSrc}" onload="window.print();window.close();" /></body></html>`);
		win.document.close();
	});
</script>

<style is:global>
	.close-btn {
		position: absolute;
		top: 1.5rem;
		right: 1.5rem;
		font-size: 2rem;
		color: #6B3E2E;
		background: none;
		border: none;
		cursor: pointer;
		text-decoration: none;
		line-height: 1;
		opacity: 0.5;
		transition: opacity 0.2s;
	}
	.close-btn:hover {
		opacity: 1;
	}

	.coloring-section {
		max-width: 1100px;
		margin: 2rem auto;
		padding: 2.5rem 2rem;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.coloring-section h2 {
		font-family: 'Baloo 2', cursive;
		font-size: 2rem;
		color: #6B3E2E;
		margin-bottom: 0.5rem;
	}

	.coloring-subtitle {
		font-family: 'Nunito', sans-serif;
		font-size: 1rem;
		color: #6B3E2E;
		opacity: 0.7;
		margin-bottom: 0.25rem;
	}

	.coloring-instructions {
		font-family: 'Nunito', sans-serif;
		font-size: 0.85rem;
		color: #FF9BB7;
		margin-bottom: 2rem;
	}

	.orientation-tabs {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		margin-bottom: 2rem;
	}

	.orientation-tab {
		font-family: 'Baloo 2', cursive;
		font-size: 0.9rem;
		font-weight: 700;
		padding: 0.5rem 1.5rem;
		border-radius: 10px;
		border: 2px solid #FF9BB7;
		background: transparent;
		color: #FF9BB7;
		cursor: pointer;
		transition: all 0.2s;
	}

	.orientation-tab:hover {
		background: #fff0f4;
	}

	.orientation-tab.active {
		background: #FF9BB7;
		color: #fff;
	}

	.coloring-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.coloring-grid.hidden {
		display: none;
	}

	.coloring-card {
		display: block;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 2px 12px rgba(107, 62, 46, 0.1);
		transition: all 0.25s;
		cursor: pointer;
		background: #fff;
		line-height: 0;
		height: fit-content;
	}

	.coloring-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 20px rgba(107, 62, 46, 0.15);
	}

	.coloring-card img {
		width: 100%;
		height: auto;
		display: block;
		opacity: 0.45;
	}

	#vertical-grid .coloring-card:nth-child(4) img,
	#vertical-grid .coloring-card:nth-child(5) img {
		opacity: 0.7;
	}


	.cp-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.7);
		z-index: 300;
		align-items: center;
		justify-content: center;
	}

	.cp-overlay.open {
		display: flex;
	}

	.cp-modal {
		background: #fff;
		border-radius: 20px;
		padding: 1.5rem;
		max-width: 500px;
		width: 90%;
		position: relative;
		text-align: center;
	}

	.cp-close {
		position: absolute;
		top: 0.75rem;
		right: 1rem;
		font-size: 1.5rem;
		background: none;
		border: none;
		color: #999;
		cursor: pointer;
	}

	.cp-close:hover {
		color: #333;
	}

	.cp-preview {
		width: 100%;
		max-height: 60vh;
		object-fit: contain;
		border-radius: 12px;
		margin-bottom: 1rem;
	}

	.cp-actions {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
	}

	.cp-btn {
		display: inline-flex;
		align-items: center;
		font-family: 'Baloo 2', cursive;
		font-size: 0.85rem;
		font-weight: 700;
		padding: 0.6rem 1.5rem;
		border-radius: 10px;
		text-decoration: none;
		transition: all 0.2s;
		cursor: pointer;
	}

	.cp-btn-print {
		background: #FF9BB7;
		color: #fff;
		border: 2px solid #FF9BB7;
		box-shadow: 0 2px 10px rgba(255, 155, 183, 0.3);
	}

	.cp-btn-print:hover {
		background: #f0839f;
		border-color: #f0839f;
		transform: translateY(-1px);
	}

	.cp-btn-download {
		background: #fff;
		color: #FF9BB7;
		border: 2px solid #FF9BB7;
	}

	.cp-btn-download:hover {
		background: #fff0f4;
		transform: translateY(-1px);
	}

	.notice {
		background: #fff5ee;
		border-radius: 12px;
		padding: 1.25rem 1.5rem;
		max-width: 600px;
		margin: 2rem auto 0;
		text-align: left;
	}

	.notice-title {
		font-family: 'Baloo 2', cursive;
		font-weight: 800;
		color: #6B3E2E;
		font-size: 0.95rem;
		margin-bottom: 0.4rem;
	}

	.notice p {
		font-family: 'Nunito', sans-serif;
		font-size: 0.8rem;
		color: #6B3E2E;
		opacity: 0.7;
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.coloring-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1rem;
		}

		.coloring-section {
			padding: 1.5rem 1rem;
		}

		.coloring-section h2 {
			font-size: 1.6rem;
		}

		.close-btn {
			top: 1rem;
			right: 1rem;
			font-size: 1.75rem;
		}

		.coloring-instructions {
			margin-bottom: 1.5rem;
		}

		.cp-modal {
			padding: 1.25rem 1rem;
		}
	}

	@media (max-width: 480px) {
		.coloring-grid {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}

		.coloring-section h2 {
			font-size: 1.4rem;
		}

		.orientation-tab {
			padding: 0.5rem 1.1rem;
		}

		.notice {
			padding: 1rem 1.1rem;
		}
	}
</style>
