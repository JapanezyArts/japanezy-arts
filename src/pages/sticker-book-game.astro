	const GAME_TIME = 120;
	const POINTS_PER_STICKER = 50;
	const TIME_BONUS_MULTIPLIER = 10;

	let placedCount = 0;
	let score = 0;
	let timeLeft = GAME_TIME;
	let timerInterval: number | null = null;
	let gameActive = false;

	// Drag state
	let draggedStickerId: string | null = null;
	let draggedElement: HTMLElement | null = null;
	let ghostEl: HTMLElement | null = null;
	let dragOffsetX = 0;
	let dragOffsetY = 0;

	const room = document.getElementById('sticker-room');
	const trayScroll = document.getElementById('tray-scroll');
	const timerEl = document.getElementById('game-timer');
	const scoreEl = document.getElementById('game-score');
	const startBtn = document.getElementById('game-start-btn') as HTMLButtonElement | null;
	const messageEl = document.getElementById('game-message');
	const container = document.getElementById('game-container');

	if (!room || !trayScroll || !timerEl || !scoreEl || !startBtn || !messageEl || !container) {
		throw new Error('Sticker game: required DOM elements not found');
	}

	function shuffle<T>(arr: T[]): T[] {
		const a = [...arr];
		for (let i = a.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[a[i], a[j]] = [a[j], a[i]];
		}
		return a;
	}

	function formatTime(s: number): string {
		const m = Math.floor(s / 60);
		const sec = s % 60;
		return `${m}:${sec.toString().padStart(2, '0')}`;
	}

	// ── Drag & Drop ──

	function startDrag(e: MouseEvent | TouchEvent, stickerId: string, trayItem: HTMLElement) {
		if (!gameActive || trayItem.classList.contains('placed')) return;
		e.preventDefault();

		draggedStickerId = stickerId;
		draggedElement = trayItem;

		const sticker = STICKERS.find(s => s.id === stickerId);
		if (!sticker) return;

		ghostEl = document.createElement('div');
		ghostEl.className = 'drag-ghost';
		ghostEl.innerHTML = sticker.svg;
		document.body.appendChild(ghostEl);

		const touch = 'touches' in e ? e.touches[0] : e;
		const rect = trayItem.getBoundingClientRect();
		dragOffsetX = touch.clientX - rect.left;
		dragOffsetY = touch.clientY - rect.top;

		moveGhost(touch.clientX, touch.clientY);
		trayItem.classList.add('dragging');
	}

	function moveGhost(clientX: number, clientY: number) {
		if (!ghostEl) return;
		ghostEl.style.left = (clientX - dragOffsetX) + 'px';
		ghostEl.style.top = (clientY - dragOffsetY) + 'px';
	}

	function onMouseMove(e: MouseEvent) {
		if (!ghostEl) return;
		e.preventDefault();
		moveGhost(e.clientX, e.clientY);
		highlightDropZone(e.clientX, e.clientY);
	}

	function onTouchMove(e: TouchEvent) {
		if (!ghostEl) return;
		e.preventDefault();
		const touch = e.touches[0];
		moveGhost(touch.clientX, touch.clientY);
		highlightDropZone(touch.clientX, touch.clientY);
	}

	function highlightDropZone(clientX: number, clientY: number) {
		document.querySelectorAll('.drop-zone.drag-over').forEach(z => z.classList.remove('drag-over'));
		if (!ghostEl) return;
		ghostEl.style.display = 'none';
		const el = document.elementFromPoint(clientX, clientY);
		ghostEl.style.display = '';
		const zone = el?.closest('.drop-zone') as HTMLElement | null;
		if (zone && !zone.classList.contains('filled')) {
			zone.classList.add('drag-over');
		}
	}

	function onDragEnd(e: MouseEvent | TouchEvent) {
		if (!ghostEl || !draggedStickerId) return;

		document.querySelectorAll('.drop-zone.drag-over').forEach(z => z.classList.remove('drag-over'));

		const touch = 'changedTouches' in e ? e.changedTouches[0] : e;

		ghostEl.style.display = 'none';
		const dropTarget = document.elementFromPoint(touch.clientX, touch.clientY);
		ghostEl.style.display = '';

		const zone = dropTarget?.closest('.drop-zone') as HTMLElement | null;

		if (zone && zone.dataset.stickerId === draggedStickerId && !zone.classList.contains('filled')) {
			zone.classList.add('filled');
			draggedElement?.classList.add('placed');
			draggedElement?.classList.remove('dragging');

			placedCount++;
			score += POINTS_PER_STICKER;
			scoreEl.textContent = `Score: ${score}`;

			if (placedCount === STICKERS.length) endGame(true);
		} else if (zone && !zone.classList.contains('filled')) {
			zone.classList.add('wrong');
			setTimeout(() => zone.classList.remove('wrong'), 400);
			draggedElement?.classList.remove('dragging');
		} else {
			draggedElement?.classList.remove('dragging');
		}

		ghostEl.remove();
		ghostEl = null;
		draggedStickerId = null;
		draggedElement = null;
	}

	// Global move/end listeners
	document.addEventListener('mousemove', onMouseMove);
	document.addEventListener('mouseup', onDragEnd);
	document.addEventListener('touchmove', onTouchMove, { passive: false });
	document.addEventListener('touchend', onDragEnd);

	// ── Game Logic ──

	function buildGame() {
		room.querySelectorAll('.drop-zone').forEach(z => z.remove());
		trayScroll.innerHTML = '';

		STICKERS.forEach(s => {
			const zone = document.createElement('div');
			zone.className = 'drop-zone';
			zone.dataset.stickerId = s.id;
			zone.style.left = s.x + '%';
			zone.style.top = s.y + '%';
			zone.style.width = s.w + '%';
			zone.style.height = s.h + '%';
			zone.innerHTML = `<div class="outline-svg">${s.svg}</div><div class="outline-border"></div>`;
			room.appendChild(zone);
		});

		const shuffled = shuffle(STICKERS);
		shuffled.forEach(s => {
			const item = document.createElement('div');
			item.className = 'tray-sticker';
			item.dataset.stickerId = s.id;
			item.innerHTML = s.svg;

			item.addEventListener('mousedown', (e) => startDrag(e, s.id, item));
			item.addEventListener('touchstart', (e) => startDrag(e, s.id, item), { passive: false });

			trayScroll.appendChild(item);
		});
	}

	function startGame() {
		placedCount = 0;
		score = 0;
		timeLeft = GAME_TIME;
		draggedStickerId = null;
		draggedElement = null;
		gameActive = true;

		scoreEl.textContent = 'Score: 0';
		timerEl.textContent = formatTime(timeLeft);
		timerEl.classList.remove('warning');
		messageEl.textContent = '';
		messageEl.className = 'game-message';
		startBtn.textContent = 'Restart';
		container.classList.add('active');

		buildGame();

		if (timerInterval) clearInterval(timerInterval);
		timerInterval = window.setInterval(() => {
			timeLeft--;
			timerEl.textContent = formatTime(timeLeft);
			if (timeLeft <= 30) timerEl.classList.add('warning');
			if (timeLeft <= 0) endGame(false);
		}, 1000);
	}

	function endGame(won: boolean) {
		gameActive = false;
		if (timerInterval) clearInterval(timerInterval);

		if (won) {
			const timeBonus = timeLeft * TIME_BONUS_MULTIPLIER;
			score += timeBonus;
			scoreEl.textContent = `Score: ${score}`;
			messageEl.textContent = `You did it! All stickers placed! +${timeBonus} time bonus!`;
			messageEl.className = 'game-message success';
		} else {
			messageEl.textContent = `Time's up! You placed ${placedCount}/${STICKERS.length} stickers.`;
			messageEl.className = 'game-message fail';
		}

		startBtn.textContent = 'Play Again';

		const highScore = parseInt(localStorage.getItem('japanezy-sticker-highscore') || '0');
		if (score > highScore) {
			localStorage.setItem('japanezy-sticker-highscore', score.toString());
			if (won) messageEl.textContent += ' New high score!';
		}
	}

	startBtn.addEventListener('click', startGame);
	buildGame();
</script>
