---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sticker Book Game - Japanezy Arts">
	<section class="sticker-game-section" id="sticker-game">
		<h2>Sticker Book Game</h2>
		<p class="game-subtitle">Drag stickers from the tray to decorate the room!</p>

		<div class="game-header">
			<div class="game-timer" id="game-timer">2:00</div>
			<div class="game-score" id="game-score">Score: 0</div>
			<button class="game-start-btn" id="game-start-btn">Start Game</button>
		</div>

		<div class="game-message" id="game-message"></div>

		<div class="game-container" id="game-container">
			<div class="sticker-room" id="sticker-room">
				<div class="room-back-wall"></div>
				<div class="room-left-wall"></div>
				<div class="room-right-wall"></div>
				<div class="room-floor"></div>
				<div class="room-baseboard"></div>
			</div>
			<div class="sticker-tray" id="sticker-tray">
				<div class="tray-label">Sticker Sheet</div>
				<div class="tray-scroll" id="tray-scroll"></div>
			</div>
		</div>
	</section>
</Layout>

<style is:global>
	/* Sticker Game — global so dynamically created elements get styled */
	.sticker-game-section {
		padding: 4rem 2rem;
		text-align: center;
		position: relative;
		z-index: 1;
		max-width: 800px;
		margin: 0 auto;
	}

	.sticker-game-section h2 {
		font-size: 2.25rem;
		margin-bottom: 0.5rem;
		color: #333;
	}

	.game-subtitle {
		color: #666;
		margin-bottom: 1.5rem;
		font-size: 1.05rem;
	}

	.game-header {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5rem;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}

	.game-timer {
		background: #fff;
		border: 3px solid #f8bbd0;
		border-radius: 10px;
		padding: 0.5rem 1.25rem;
		font-size: 1.5rem;
		font-weight: 700;
		color: #9b59b6;
		font-family: 'Noto Serif JP', serif;
		min-width: 90px;
	}

	.game-timer.warning {
		border-color: #e53935;
		color: #e53935;
		animation: pulse 0.5s ease-in-out infinite alternate;
	}

	@keyframes pulse {
		from { transform: scale(1); }
		to { transform: scale(1.05); }
	}

	.game-score {
		background: #fff;
		border: 3px solid #d5b3f5;
		border-radius: 10px;
		padding: 0.5rem 1.25rem;
		font-size: 1.2rem;
		font-weight: 700;
		color: #9b59b6;
	}

	.game-start-btn {
		background: #d5b3f5;
		color: #fff;
		border: none;
		padding: 0.65rem 2rem;
		border-radius: 8px;
		font-size: 1.05rem;
		font-weight: 700;
		cursor: pointer;
		transition: background 0.2s;
		font-family: 'Inter', sans-serif;
	}

	.game-start-btn:hover {
		background: #c9a3eb;
	}

	.game-message {
		font-size: 1.3rem;
		font-weight: 700;
		color: #9b59b6;
		min-height: 2rem;
		margin-bottom: 1rem;
	}

	.game-message.success { color: #4caf50; }
	.game-message.fail { color: #e53935; }

	.game-container {
		opacity: 0.5;
		pointer-events: none;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 24px rgba(155, 89, 182, 0.2);
	}

	.game-container.active {
		opacity: 1;
		pointer-events: auto;
	}

	/* Isometric Kawaii Room (Baa Baa House inspired) */
	.sticker-room {
		position: relative;
		width: 100%;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: #fef9f0;
	}

	.room-back-wall {
		position: absolute;
		top: 0;
		left: 10%;
		right: 10%;
		height: 60%;
		background:
			radial-gradient(circle at 20% 30%, rgba(248,187,208,0.1) 2px, transparent 2px),
			radial-gradient(circle at 60% 50%, rgba(248,187,208,0.1) 2px, transparent 2px),
			radial-gradient(circle at 80% 20%, rgba(248,187,208,0.1) 2px, transparent 2px),
			radial-gradient(circle at 40% 70%, rgba(248,187,208,0.1) 2px, transparent 2px),
			linear-gradient(180deg, #fff8e1 0%, #fff3cd 60%, #ffe0b2 100%);
		background-size: 40px 40px, 50px 50px, 35px 35px, 45px 45px, 100% 100%;
		border-bottom: 5px solid #e8c0a8;
	}

	.room-left-wall {
		position: absolute;
		top: 0;
		left: 0;
		width: 10%;
		height: 100%;
		background: linear-gradient(90deg, #f5e6c8 0%, #fcefd5 100%);
		clip-path: polygon(0 0, 100% 0, 100% 60%, 0 100%);
	}

	.room-right-wall {
		position: absolute;
		top: 0;
		right: 0;
		width: 10%;
		height: 100%;
		background: linear-gradient(270deg, #f5e6c8 0%, #fcefd5 100%);
		clip-path: polygon(0 0, 100% 0, 100% 100%, 0 60%);
	}

	.room-floor {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 40%;
		background:
			repeating-linear-gradient(
				90deg,
				rgba(180,140,100,0.15) 0px, rgba(180,140,100,0.15) 1px,
				transparent 1px, transparent 60px
			),
			linear-gradient(180deg, #f0d9b5 0%, #e6c9a0 100%);
		clip-path: polygon(10% 0%, 90% 0%, 100% 100%, 0% 100%);
	}

	.room-baseboard {
		position: absolute;
		top: 60%;
		left: 10%;
		right: 10%;
		height: 5px;
		background: #daa88a;
		border-radius: 0 0 2px 2px;
	}

	/* Drop zones in room */
	.drop-zone {
		position: absolute;
		transition: all 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
		touch-action: none;
	}

	.drop-zone .outline-svg {
		width: 100%;
		height: 100%;
		opacity: 0.25;
		filter: grayscale(0.6);
	}

	.drop-zone .outline-border {
		position: absolute;
		inset: -3px;
		border: 2px dashed rgba(155, 89, 182, 0.4);
		border-radius: 8px;
	}

	.drop-zone.drag-over .outline-border {
		border-color: #9b59b6;
		background: rgba(213, 179, 245, 0.2);
		border-width: 3px;
	}

	.drop-zone.filled {
		cursor: default;
	}

	.drop-zone.filled .outline-svg {
		opacity: 1;
		filter: none;
		animation: stickerPop 0.4s ease;
	}

	.drop-zone.filled .outline-border {
		border: 2px solid #81c784;
		background: rgba(129, 199, 132, 0.08);
	}

	.drop-zone.wrong {
		animation: shake 0.3s ease;
	}

	.drop-zone.wrong .outline-border {
		border-color: #e53935;
		background: rgba(229, 57, 53, 0.1);
	}

	@keyframes stickerPop {
		0% { transform: scale(0.3); opacity: 0; }
		50% { transform: scale(1.15); }
		100% { transform: scale(1); opacity: 1; }
	}

	@keyframes shake {
		0%, 100% { transform: translateX(0); }
		25% { transform: translateX(-4px); }
		75% { transform: translateX(4px); }
	}

	/* Sticker Tray */
	.sticker-tray {
		background: #fff;
		border-top: 3px dashed #f8bbd0;
		padding: 0.75rem;
		position: relative;
	}

	.tray-label {
		position: absolute;
		top: -12px;
		left: 50%;
		transform: translateX(-50%);
		background: #f8bbd0;
		color: #fff;
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.15rem 0.75rem;
		border-radius: 4px;
	}

	.tray-scroll {
		display: flex;
		gap: 0.5rem;
		overflow-x: auto;
		padding: 0.5rem 0.25rem;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: thin;
		scrollbar-color: #d5b3f5 #f0d4e8;
	}

	.tray-scroll::-webkit-scrollbar { height: 6px; }
	.tray-scroll::-webkit-scrollbar-track { background: #f0d4e8; border-radius: 3px; }
	.tray-scroll::-webkit-scrollbar-thumb { background: #d5b3f5; border-radius: 3px; }

	.tray-sticker {
		flex: 0 0 65px;
		height: 65px;
		background: #fef9f0;
		border: 2px solid #f8bbd0;
		border-radius: 10px;
		cursor: grab;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s;
		user-select: none;
		-webkit-user-select: none;
		padding: 4px;
		touch-action: none;
	}

	.tray-sticker:hover {
		transform: scale(1.08);
		box-shadow: 0 3px 10px rgba(155, 89, 182, 0.25);
	}

	.tray-sticker:active {
		cursor: grabbing;
	}

	.tray-sticker.dragging {
		opacity: 0.3;
		transform: scale(0.95);
	}

	.tray-sticker.placed {
		opacity: 0.15;
		pointer-events: none;
		transform: none;
		border-color: #81c784;
	}

	.tray-sticker svg { width: 100%; height: 100%; }

	/* Drag ghost */
	.drag-ghost {
		position: fixed;
		width: 70px;
		height: 70px;
		pointer-events: none;
		z-index: 9999;
		opacity: 0.85;
		filter: drop-shadow(0 4px 12px rgba(155,89,182,0.4));
		transform: scale(1.1);
		transition: transform 0.1s;
	}

	.drag-ghost svg { width: 100%; height: 100%; }

	@media (max-width: 768px) {
		.sticker-game-section {
			padding: 2.5rem 0.5rem;
		}

		.sticker-game-section h2 { font-size: 1.75rem; }
		.game-timer { font-size: 1.2rem; padding: 0.4rem 1rem; }

		.tray-sticker {
			flex: 0 0 55px;
			height: 55px;
		}

		.drag-ghost {
			width: 60px;
			height: 60px;
		}
	}
</style>

