---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Drawing Sent! - Japanezy Arts">
	<section class="thanks-section">
		<h2>Thank you!</h2>
		<p>Thank you for sending Japanezy some fan art. She will receive it and maybe even give you a shoutout!</p>
		<a href="/" class="btn thanks-btn">Return to Home Page</a>
	</section>
</Layout>

<style>
	.thanks-section {
		padding: 6rem 2rem;
		text-align: center;
		position: relative;
		z-index: 1;
		max-width: 500px;
		margin: 0 auto;
	}

	.thanks-section h2 {
		font-size: 2.25rem;
		color: #9b59b6;
		margin-bottom: 1rem;
	}

	.thanks-section p {
		font-size: 1.1rem;
		color: #555;
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.thanks-btn {
		background: #d5b3f5;
		color: #fff;
		padding: 0.85rem 2rem;
	}

	.thanks-btn:hover {
		background: #c9a3eb;
	}
</style>
