---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cart - Japanezy Arts">
	<!-- No rewards popup -->
	<div class="reward-popup-overlay" id="no-rewards-popup">
		<div class="reward-popup">
			<p>Sorry, you do not have any rewards. Please try spinning the wheel.</p>
			<button id="close-no-rewards">OK</button>
		</div>
	</div>

	<!-- Reward select popup -->
	<div class="reward-select-overlay" id="reward-select-popup">
		<div class="reward-select-modal">
			<h3>Choose a Reward</h3>
			<div class="reward-select-list" id="reward-select-list"></div>
			<button class="reward-select-cancel" id="reward-select-cancel">Cancel</button>
		</div>
	</div>

	<!-- Reward info popup -->
	<div class="reward-popup-overlay" id="reward-info-popup">
		<div class="reward-popup">
			<h3 id="reward-info-title"></h3>
			<p id="reward-info-desc"></p>
			<button id="close-reward-info">OK</button>
		</div>
	</div>

	<section class="cart-section">
		<h2>Your Cart</h2>

		<div class="cart-empty" id="cart-empty">
			<p>Your cart is empty!</p>
			<a href="/#products" class="btn btn-primary">Browse Products</a>
		</div>

		<div class="cart-items" id="cart-items"></div>

		<div class="cart-footer" id="cart-footer" style="display: none;">
			<div class="cart-totals-breakdown">
				<div class="cart-line">
					<span>Items Total:</span>
					<span id="cart-items-total">$0</span>
				</div>
				<h3 class="plus-tax-heading">Plus tax</h3>
				<div class="cart-total">
					<span>Subtotal:</span>
					<span id="cart-total-price">$0</span>
				</div>
			</div>
			<div class="cart-actions">
				<button class="btn btn-clear" id="clear-cart">Clear Cart</button>
				<button class="btn btn-checkout" id="checkout-btn">Proceed to Checkout</button>
			</div>
		</div>
	</section>
</Layout>

<style is:global>
	.cart-section {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 2rem;
		position: relative;
		z-index: 1;
	}

	.cart-section h2 {
		font-size: 2.25rem;
		color: #333;
		margin-bottom: 2rem;
		text-align: center;
	}

	.cart-empty {
		text-align: center;
		padding: 3rem;
	}

	.cart-empty p {
		font-size: 1.2rem;
		color: #888;
		margin-bottom: 1.5rem;
	}

	.btn {
		display: inline-block;
		padding: 0.85rem 2rem;
		border-radius: 6px;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.2s;
		cursor: pointer;
		border: none;
	}

	.btn-primary {
		background: #d5b3f5;
		color: #fff;
	}

	.btn-primary:hover {
		background: #c9a3eb;
	}

	.cart-items {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.cart-item-wrapper {
		background: #fff;
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 2px 12px rgba(155, 89, 182, 0.1);
		position: relative;
	}

	.reward-badge-row {
		position: absolute;
		top: 8px;
		right: 8px;
		display: flex;
		gap: 0.5rem;
		z-index: 2;
	}

	.reward-badge-btn {
		background: #b3d4fc;
		color: #333;
		border: none;
		font-size: 1rem;
		font-weight: 700;
		padding: 0.6rem 1.2rem;
		border-radius: 6px;
		cursor: pointer;
		transition: background 0.2s;
	}

	.reward-badge-btn:hover {
		background: #9ec5f7;
	}

	.another-reward-btn {
		background: #f8bbd0;
		color: #fff;
		border: none;
		font-size: 0.85rem;
		font-weight: 700;
		padding: 0.6rem 1rem;
		border-radius: 6px;
		cursor: pointer;
		transition: background 0.2s;
	}

	.another-reward-btn:hover {
		background: #f48fb1;
	}

	.cart-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 0.75rem;
	}

	.cart-item-bottom {
		display: flex;
		gap: 0;
	}

	.cart-item img {
		width: 161px !important;
		height: 161px !important;
		max-width: 161px !important;
		max-height: 161px !important;
		object-fit: cover;
		border-radius: 4px;
		flex-shrink: 0;
	}

	.cart-item-details {
		flex: 1;
	}

	.cart-item-details h3 {
		font-size: 0.85rem;
		margin-bottom: 0.15rem;
		color: #333;
	}

	.cart-item-details .item-price {
		font-weight: 600;
		color: #9b59b6;
		font-size: 0.85rem;
	}

	.remove-btn {
		background: #f8bbd0;
		border: none;
		color: #ffffff;
		font-size: 0.85rem;
		font-weight: 700;
		cursor: pointer;
		padding: 0.5rem 1rem;
		border-radius: 0 0 8px 0;
		transition: background 0.2s;
		flex: 1;
	}

	.remove-btn:hover {
		background: #f48fb1;
	}

	.apply-reward-btn {
		background: #9b59b6;
		color: #ffffff;
		border: none;
		font-size: 0.85rem;
		font-weight: 700;
		cursor: pointer;
		padding: 0.5rem 1rem;
		border-radius: 0 0 0 8px;
		transition: all 0.2s;
		flex: 1;
	}

	.apply-reward-btn:hover {
		background: #8e44ad;
	}

	.apply-reward-btn.dimmed {
		background: #9b59b6;
		color: #fff;
		opacity: 0.4;
		cursor: not-allowed;
	}

	.apply-reward-btn.applied {
		background: #d5b3f5;
		color: #fff;
		cursor: default;
	}

	.reward-applied-label {
		font-size: 0.7rem;
		color: #4caf50;
		font-weight: 600;
	}

	.discounted-price {
		color: #ff0000 !important;
		font-weight: 700;
	}

	.discount-green {
		color: #2e7d32 !important;
		font-weight: 700;
	}

	.original-item-price {
		text-decoration: line-through;
		color: #e53935;
		font-size: 0.75rem;
		margin-right: 0.3rem;
	}

	/* Reward popup */
	.reward-popup-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.5);
		z-index: 300;
		align-items: center;
		justify-content: center;
	}

	.reward-popup-overlay.open {
		display: flex;
	}

	.reward-popup {
		background: #fff;
		border-radius: 12px;
		padding: 2rem;
		text-align: center;
		max-width: 360px;
		width: 90%;
		box-shadow: 0 8px 32px rgba(0,0,0,0.2);
	}

	.reward-popup p {
		font-size: 1.05rem;
		color: #333;
		margin-bottom: 1.5rem;
	}

	.reward-popup button {
		background: #d5b3f5;
		color: #fff;
		border: none;
		padding: 0.6rem 1.5rem;
		border-radius: 6px;
		font-weight: 600;
		cursor: pointer;
		font-size: 0.95rem;
	}

	.reward-popup button:hover {
		background: #c9a3eb;
	}

	.reward-select-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.5);
		z-index: 300;
		align-items: center;
		justify-content: center;
	}

	.reward-select-overlay.open {
		display: flex;
	}

	.reward-select-modal {
		background: #fff;
		border-radius: 12px;
		padding: 2rem;
		text-align: center;
		max-width: 360px;
		width: 90%;
		box-shadow: 0 8px 32px rgba(0,0,0,0.2);
	}

	.reward-select-modal h3 {
		margin-bottom: 1rem;
		color: #333;
	}

	.reward-select-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.reward-select-item {
		background: #f8f0ff;
		border: none;
		padding: 0.6rem 1rem;
		border-radius: 6px;
		font-weight: 600;
		cursor: pointer;
		font-size: 0.95rem;
		transition: background 0.2s;
	}

	.reward-select-item:hover {
		background: #e8d0f8;
	}

	.reward-select-cancel {
		background: #f0d4e8;
		color: #666;
		border: none;
		padding: 0.5rem 1.2rem;
		border-radius: 6px;
		font-weight: 600;
		cursor: pointer;
		font-size: 0.9rem;
	}

	.cart-footer {
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 2px solid #f0d4e8;
	}

	.cart-totals-breakdown {
		margin-bottom: 1.5rem;
	}

	.cart-line {
		display: flex;
		justify-content: space-between;
		font-size: 1.1rem;
		font-weight: 600;
		color: #333;
		margin-bottom: 0.5rem;
	}

	.plus-tax-heading {
		color: #e53935;
		font-size: 1.1rem;
		text-align: center;
		margin: 0.75rem 0;
	}

	.cart-total {
		display: flex;
		justify-content: space-between;
		font-size: 1.4rem;
		font-weight: 700;
		color: #333;
		padding-top: 0.5rem;
		border-top: 1px solid #f0d4e8;
		font-family: 'Noto Serif JP', serif;
	}

	.cart-total span:last-child {
		color: #9b59b6;
	}

	.cart-actions {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
	}

	.btn-clear {
		background: #f0d4e8;
		color: #666;
	}

	.btn-clear:hover {
		background: #e8c0d8;
	}

	.btn-checkout {
		background: #b3d4fc;
		color: #333;
		flex: 1;
	}

	.btn-checkout:hover {
		background: #9ec5f7;
	}

	@media (max-width: 768px) {
		.cart-section {
			padding: 1.5rem 1rem;
		}

		.cart-section h2 {
			font-size: 1.75rem;
			margin-bottom: 1.25rem;
		}

		.cart-item {
			gap: 0.5rem;
			padding: 0.5rem;
		}

		.cart-item img {
			width: 100px !important;
			height: 100px !important;
			max-width: 100px !important;
			max-height: 100px !important;
		}

		.cart-item-details h3 {
			font-size: 0.8rem;
		}

		.reward-badge-row {
			flex-wrap: wrap;
			gap: 0.3rem;
		}

		.reward-badge-btn {
			font-size: 0.8rem;
			padding: 0.4rem 0.8rem;
		}

		.another-reward-btn {
			font-size: 0.7rem;
			padding: 0.4rem 0.7rem;
		}

		.cart-actions {
			flex-direction: column;
		}

		.btn-clear,
		.btn-checkout {
			width: 100%;
			text-align: center;
		}

		.cart-total {
			font-size: 1.2rem;
		}
	}
</style>

<script>
	function getRewards(): { label: string; date: string }[] {
		return JSON.parse(localStorage.getItem('japanezy-rewards') || '[]');
	}

	function hasRewards(): boolean {
		return getRewards().length > 0;
	}

	function applyDiscount(price: number, rewardLabel: string): number {
		if (rewardLabel === '10% Off') return price * 0.9;
		if (rewardLabel === '50% Off') return price * 0.5;
		return price;
	}

	function isDiscountReward(label: string): boolean {
		return label === '10% Off' || label === '50% Off';
	}

	let pendingRewardIndex: number | null = null;

	function renderCart() {
		const cart = JSON.parse(localStorage.getItem('japanezy-cart') || '[]');
		const itemsEl = document.getElementById('cart-items')!;
		const emptyEl = document.getElementById('cart-empty')!;
		const footerEl = document.getElementById('cart-footer')!;
		const totalEl = document.getElementById('cart-total-price')!;

		if (cart.length === 0) {
			emptyEl.style.display = 'block';
			footerEl.style.display = 'none';
			itemsEl.innerHTML = '';
			return;
		}

		emptyEl.style.display = 'none';
		footerEl.style.display = 'block';

		const rewards = hasRewards();
		let total = 0;

		itemsEl.innerHTML = cart.map((item: any, i: number) => {
			// Migrate old single reward to array
			if (item.appliedReward && !item.appliedRewards) {
				item.appliedRewards = [item.appliedReward];
				delete item.appliedReward;
				localStorage.setItem('japanezy-cart', JSON.stringify(cart));
			}

			const appliedRewards: string[] = item.appliedRewards || [];
			const originalPrice = parseFloat(item.price.replace('$', ''));
			let displayPrice = originalPrice;
			let priceHtml = `<span class="item-price">${item.price}</span>`;
			let rewardHtml = '';

			// Check for discount rewards
			const discountReward = appliedRewards.find(r => isDiscountReward(r));
			const hasBonusGift = appliedRewards.includes('Bonus Gift');
			const hasFreeSticker = appliedRewards.includes('Free Sticker');

			if (discountReward) {
				displayPrice = applyDiscount(originalPrice, discountReward);
				priceHtml = `<span class="original-item-price">${item.price}</span><span class="item-price discount-green">$${displayPrice.toFixed(2)}</span>`;
				rewardHtml = `<span class="reward-applied-label">${discountReward} applied</span>`;
			}

			total += displayPrice;

			// Badge buttons for Bonus Gift / Free Sticker
			let badgeHtml = '';
			const badgeButtons: string[] = [];
			if (hasBonusGift) badgeButtons.push(`<button class="reward-badge-btn" data-reward-type="Bonus Gift">Bonus Gift</button>`);
			if (hasFreeSticker) badgeButtons.push(`<button class="reward-badge-btn" data-reward-type="Free Sticker">Free Sticker</button>`);

			// Always show "Have another reward?" button on every item
			const hasAnotherBtn = `<button class="another-reward-btn" data-index="${i}">Have another reward?</button>`;
			badgeHtml = `<div class="reward-badge-row">${badgeButtons.join('')}${hasAnotherBtn}</div>`;

			// Bottom buttons
			const hasAnyReward = appliedRewards.length > 0;
			const btnClass = rewards ? 'apply-reward-btn' : 'apply-reward-btn dimmed';
			const applyBtn = hasAnyReward && !badgeButtons.length
				? `<button class="apply-reward-btn applied">Reward Applied</button>`
				: hasAnyReward && badgeButtons.length
				? `<button class="apply-reward-btn applied">Reward Applied</button>`
				: `<button class="${btnClass}" data-index="${i}">Apply Reward</button>`;

			return `
				<div class="cart-item-wrapper">
					${badgeHtml}
					<div class="cart-item">
						<img src="${item.image}" alt="${item.name}" />
						<div class="cart-item-details">
							<h3>${item.name}</h3>
							${priceHtml}
							${rewardHtml}
						</div>
					</div>
					<div class="cart-item-bottom">
						${applyBtn}
						<button class="remove-btn" data-index="${i}">Remove</button>
					</div>
				</div>
			`;
		}).join('');

		const itemsTotalEl = document.getElementById('cart-items-total')!;
		const tax = total * 0.0825;
		const subtotal = total + tax;
		itemsTotalEl.textContent = '$' + total.toFixed(2);
		totalEl.textContent = '$' + subtotal.toFixed(2);

		document.querySelectorAll('.remove-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				const idx = parseInt((btn as HTMLButtonElement).dataset.index!);
				cart.splice(idx, 1);
				localStorage.setItem('japanezy-cart', JSON.stringify(cart));
				renderCart();
			});
		});

		document.querySelectorAll('.reward-badge-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				const rewardType = (btn as HTMLButtonElement).dataset.rewardType;
				const titleEl = document.getElementById('reward-info-title')!;
				const descEl = document.getElementById('reward-info-desc')!;
				if (rewardType === 'Bonus Gift') {
					titleEl.textContent = 'Bonus Gift';
					descEl.textContent = 'The price has not changed, but we will give you a bonus gift with your order now.';
				} else if (rewardType === 'Free Sticker') {
					titleEl.textContent = 'Free Sticker';
					descEl.textContent = 'The price has not changed, but we will include a free sticker in your order.';
				}
				document.getElementById('reward-info-popup')!.classList.add('open');
			});
		});

		document.querySelectorAll('.another-reward-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				if (!hasRewards()) {
					document.getElementById('no-rewards-popup')!.classList.add('open');
					return;
				}
				pendingRewardIndex = parseInt((btn as HTMLButtonElement).dataset.index!);
				showRewardSelect();
			});
		});

		document.querySelectorAll('.apply-reward-btn:not(.applied)').forEach(btn => {
			btn.addEventListener('click', () => {
				if (!hasRewards()) {
					document.getElementById('no-rewards-popup')!.classList.add('open');
					return;
				}
				pendingRewardIndex = parseInt((btn as HTMLButtonElement).dataset.index!);
				showRewardSelect();
			});
		});
	}

	function showRewardSelect() {
		const rewards = getRewards();
		const listEl = document.getElementById('reward-select-list')!;
		listEl.innerHTML = rewards.map((r, i) =>
			`<button class="reward-select-item" data-reward-index="${i}">${r.label} (${r.date})</button>`
		).join('');

		document.getElementById('reward-select-popup')!.classList.add('open');

		document.querySelectorAll('.reward-select-item').forEach(btn => {
			btn.addEventListener('click', () => {
				const rewardIdx = parseInt((btn as HTMLButtonElement).dataset.rewardIndex!);
				const rewards = getRewards();
				const reward = rewards[rewardIdx];
				const cart = JSON.parse(localStorage.getItem('japanezy-cart') || '[]');

				if (pendingRewardIndex !== null && cart[pendingRewardIndex]) {
					if (!cart[pendingRewardIndex].appliedRewards) {
						cart[pendingRewardIndex].appliedRewards = [];
					}
					cart[pendingRewardIndex].appliedRewards.push(reward.label);
					// Keep old field for backwards compat
					cart[pendingRewardIndex].appliedReward = reward.label;
					localStorage.setItem('japanezy-cart', JSON.stringify(cart));

					// Remove used reward
					rewards.splice(rewardIdx, 1);
					localStorage.setItem('japanezy-rewards', JSON.stringify(rewards));
				}

				document.getElementById('reward-select-popup')!.classList.remove('open');
				pendingRewardIndex = null;
				renderCart();
			});
		});
	}

	document.getElementById('close-reward-info')!.addEventListener('click', () => {
		document.getElementById('reward-info-popup')!.classList.remove('open');
	});

	document.getElementById('reward-info-popup')!.addEventListener('click', (e) => {
		if (e.target === document.getElementById('reward-info-popup')) {
			document.getElementById('reward-info-popup')!.classList.remove('open');
		}
	});

	document.getElementById('close-no-rewards')!.addEventListener('click', () => {
		document.getElementById('no-rewards-popup')!.classList.remove('open');
	});

	document.getElementById('no-rewards-popup')!.addEventListener('click', (e) => {
		if (e.target === document.getElementById('no-rewards-popup')) {
			document.getElementById('no-rewards-popup')!.classList.remove('open');
		}
	});

	document.getElementById('reward-select-cancel')!.addEventListener('click', () => {
		document.getElementById('reward-select-popup')!.classList.remove('open');
		pendingRewardIndex = null;
	});

	document.getElementById('reward-select-popup')!.addEventListener('click', (e) => {
		if (e.target === document.getElementById('reward-select-popup')) {
			document.getElementById('reward-select-popup')!.classList.remove('open');
			pendingRewardIndex = null;
		}
	});

	document.getElementById('clear-cart')!.addEventListener('click', () => {
		localStorage.removeItem('japanezy-cart');
		renderCart();
	});

	document.getElementById('checkout-btn')!.addEventListener('click', () => {
		const cart = JSON.parse(localStorage.getItem('japanezy-cart') || '[]');
		if (cart.length === 0) return;
		window.location.href = '/checkout';
	});

	renderCart();
</script>
